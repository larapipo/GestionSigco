  object QUpdateLiqFD: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'Update liquidacion_tc_cab c set c.fecha        = :fecha,'
      '                                c.fecha_fiscal = :fechaFiscal,'
      '                                c.contabiliza  = :contabiliza,'
      '                                c.ing_libroiva = :ingIva,'
      '                                c.id_cta_banco = :id_cta'
      'where c.id = :idLiq')
    Left = 256
    Top = 280
    ParamData = <
      item
        Name = 'FECHA'
        ParamType = ptInput
      end
      item
        Name = 'FECHAFISCAL'
        ParamType = ptInput
      end
      item
        Name = 'CONTABILIZA'
        ParamType = ptInput
      end
      item
        Name = 'INGIVA'
        ParamType = ptInput
      end
      item
        Name = 'ID_CTA'
        ParamType = ptInput
      end
      item
        Name = 'IDLIQ'
        ParamType = ptInput
      end>
  end
