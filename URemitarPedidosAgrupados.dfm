  object QClientesPedidos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'SELECT c.cliente,cl.nombre,cl.razon_social FROM plantilla_pedido' +
        '_cab c'
      'LEFT JOIN clientes cl oN cl.codigo = c.cliente'
      'WHERE c.facturado = '#39'N'#39
      'GROUP BY '
      '    c.cliente, cl.nombre, cl.razon_social'
      'ORDER BY '
      '    c.cliente, MAX(c.id) DESC;')
    Left = 296
    Top = 481
    object QClientesPedidosCLIENTE: TStringField
      FieldName = 'CLIENTE'
      Origin = 'CLIENTE'
      Size = 6
    end
