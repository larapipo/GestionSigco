  object QPedidos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select c.id,c.fecha,c.cliente,cl.nombre,cl.razon_social,c.id_sec' +
        'tor,se.detalle as NombreSector from plantilla_pedido_cab c'
      'left join clientes cl on cl.codigo=c.cliente'
      'left join plantilla_pedido_sector se on se.id=c.id_sector'
      'where c.facturado='#39'N'#39' order by c.cliente,c.id desc')
    Left = 296
    Top = 353
    object QPedidosID: TIntegerField
      DisplayLabel = 'Nro.Pedido'
      FieldName = 'ID'
      Origin = 'ID'
      ProviderFlags = [pfInUpdate, pfInWhere, pfInKey]
      Required = True
    end
