  object QStock: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select s.codigo_stk,s.unidad, s.REEMPLAZO_STK, s.detalle_stk,s.D' +
        'ETALLE_STK_ADICIONAL, s.fijacion_precio_total as Costo, l.iva_ta' +
        'sa as Iva,'
      ' (l.precio_gravado + l.precio_exento) as PrecioSinIva,'
      ' (l.precio) as PrecioConIva,'
      
        ' s.publicar_web,s.fuap,s.fecha_alta,s.moneda,m.cotizacion,m.sign' +
        'o,s.plu,'
      
        ' ((l.precio_gravado + l.precio_exento) * m.cotizacion) as Precio' +
        'SinIvaPeso,'
      ' (l.precio * m.cotizacion ) as PrecioConIvaPeso,'
      ' (select sum(dpk.fisico)'
      
        '    from depositostk dpk where dpk.codigo_stk=s.codigo_stk and (' +
        'dpk.codigo_deposito = :deposito or :deposito = -1)) as Existenci' +
        'a,'
      '  s.articulo_variable,s.codigo_art_variable'
      '   from stock s'
      'left join gravamen g on g.codigo=s.tasa_iva'
      
        'left join listaprecioespecialart l on l.codigoarticulo=s.codigo_' +
        'stk'
      'left join monedas m on m.id=s.moneda'
      'left join rubros r on r.codigo_rubro=s.rubro_stk'
      'left join subrubros sr on sr.codigo_subrubro=s.subrubro_stk'
      'left join marcas mk on mk.marca_stk=s.marca_stk'
      ''
      'where (s.rubro_stk = :rubro or :rubro = '#39'***'#39') and'
      '      (s.subrubro_stk = :subrubro or :subrubro = '#39'*****'#39' ) and'
      
        '      (s.marca_stk = :marca or :marca = '#39'****'#39') and  l.id_cab= :' +
        'Lista'
      ''
      'order by s.detalle_stk')
    Left = 328
    Top = 456
    ParamData = <
      item
        Position = 1
        Name = 'deposito'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'RUBRO'
