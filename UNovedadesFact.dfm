  object QNovedadesFP: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select *'
      'from ('
      '    select'
      '        f.fechavta,'
      '        c.nombre,'
      '        f.nrocpbte,'
      '        n.detalle,'
      '        n.precio_old,'
      '        n.precio,'
      '        fd.cantidad,'
      '        case'
      '            when n.precio_old = 0 then 0'
      
        '            else ((n.precio - n.precio_old) / n.precio_old) * 10' +
        '0'
      '        end as diferencia,'
      '        (n.precio_old - n.precio) as diferenciaNro,'
      '        ((n.precio_old - n.precio) * fd.cantidad) as totaldif,'
      '        n.usuario,'
      ''
      '        row_number() over ('
      '            partition by f.nrocpbte, n.detalle'
      '            order by n.id -- o cualquier campo'
      '        ) as rn'
      ''
      '    from fcvtadet_novedades n'
      '    inner join fcvtacab f on f.id_fc = n.id_cabfac'
      '    inner join clientes c on c.codigo = f.codigo'
      '    inner join fcvtadet fd '
      '        on fd.id_cabfac = n.id_cabfac'
      '       and fd.codigoarticulo = n.codigo'
      '    inner join movccvta mov on mov.id_cpbte = n.id_cabfac'
      ''
      '    where'
      '        f.fechavta between :desde and :hasta'
      '        and (f.vendedor = :vendedor or :vendedor = '#39'******'#39')'
      '        and mov.saldo = 0'
      ')'
      'where rn = 1;')
    Left = 633
    Top = 281
    ParamData = <
      item
        Position = 1
        Name = 'DESDE'
        DataType = ftTimeStamp
        ParamType = ptInput
        Value = Null
      end
      item
        Position = 2
        Name = 'HASTA'
        DataType = ftTimeStamp
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'VENDEDOR'
        DataType = ftString
        ParamType = ptInput
        Size = 6
      end>
  end
  object DSPNovedadesSP: TDataSetProvider
    DataSet = QNovedadesFP
    Left = 705
    Top = 281
  end
