  object QAdelantos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select a.*, s.detalle as MuestraSucursal,'
      
        'cp.denominacion as MuestraComprobante,cp.id_comprobante as id_ti' +
        'pocomprobante from adelantos_sueldo a '
      'left join sucursal s on s.codigo=a.sucursal'
      'left join comprobantes cp on cp.clase_comprob=a.ClaseCpbte and'
      '          cp.letra=a.Letra and'
      '          cp.sucursal=a.sucursal and'
      '          cp.tipo_comprob=a.tipocpbte and'
      '          cp.compra_venta='#39'C'#39
      'where a.id=:id and a.TipoCpbte=:TipoCpbte')
    Left = 216
    Top = 520
    ParamData = <
