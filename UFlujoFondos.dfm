  object QIngresosDet: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select c.anio,c.mes,c.tipo_pago, t.detalle as MuestraTipoPago,c.' +
        'tipo_comprob ,c.sucursal,'
      
        '       sum( c.debe) as debe  , sum(c.haber) as haber from tabla_' +
        'resumen_caja_mov c'
      'left join tipopago t on t.id_tpago=c.tipo_pago'
      'where c.tipo_operacion='#39'I'#39' and'
      '      c.tipo_comprob<>'#39'QX'#39' and'
