        'ursal = -1 )'
      
        'group by c.anio,c.mes,c.tipo_pago,t.detalle,c.tipo_comprob,c.suc' +
        'ursal'
      'order by c.sucursal, c.anio,c.mes,c.tipo_pago,c.tipo_comprob')
