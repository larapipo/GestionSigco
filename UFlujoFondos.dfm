  object QGastosEgresos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select extract(year from ec.fechagasto) as anio,extract(month fr' +
        'om ec.fechagasto) as mes,'
      
        ' ec.rubrogasto,gr.detalle as MuestraRubro, ec.codigogasto,gc.det' +
        'alle as MuestraCtaGasto,ec.sucursalventa, sum(ec.importe) from e' +
        'gr_caja_detalle ec'
      'left join gastos_cuentas gc on gc.codigo=ec.codigogasto'
      'left join gastos_rubros gr on gr.codigo=ec.rubrogasto'
      ''
      
        'where ec.fechagasto between :desde and :hasta and ( ec.sucursalv' +
        'enta = :sucursal or :sucursal = -1)'
      
        'group by ec.fechagasto, ec.codigogasto,gc.detalle,ec.rubrogasto,' +
        'gr.detalle, ec.sucursalventa'
      'ORDER BY ec.sucursalventa,EC.fechagasto')
    Left = 392
    Top = 152
    ParamData = <
      item
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
