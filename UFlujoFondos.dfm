  object QIngresos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select c.anio,c.mes,c.tipo_pago,t.detalle as MuestraTipoPago,c.s' +
        'ucursal,'
      
        '       sum( c.debe) as debe  , sum(c.haber) as haber from tabla_' +
        'resumen_caja_mov c'
      'left join tipopago t on t.id_tpago=c.tipo_pago'
      'where c.tipo_operacion='#39'I'#39' and'
      '      c.tipo_comprob<>'#39'QX'#39' and'
      '      c.tipo_comprob<>'#39'CX'#39' and'
      '      c.tipo_comprob<>'#39'QT'#39' and'
      '      c.tipo_comprob<>'#39'QR'#39' and'
      
        '      c.tipo_comprob<>'#39'DA'#39' and  ( c.sucursal = :sucursal or :suc' +
        'ursal = -1 )'
      'group by c.anio,c.mes,c.tipo_pago,t.detalle,c.sucursal'
      'order by c.sucursal, c.anio,c.mes,c.tipo_pago')
    Left = 33
    Top = 256
    ParamData = <
      item
        Position = 1
        Name = 'sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
