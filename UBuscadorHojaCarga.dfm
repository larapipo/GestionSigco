  object QHojaCab: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.*,p.nombre as MuestraResponsable from hojacarga_cab c'
      'left join personal p on p.codigo=c.responsable'
      'order by c.id Desc')
