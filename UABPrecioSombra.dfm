  object QHayCambios: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select count(s.codigo_stk) from stock s'
      'where s.costo_exento_sombra>0 or s.costo_gravado_sombra>0')
    Left = 656
    Top = 80
  end
  object QHistorico: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select h.id,h.fecha_aplicacion,h.usuario from HISTORICO_PRECIO_S' +
        'OMBRA h'
      'group by h.id,h.fecha_aplicacion,h.usuario'
      'order by h.fecha_aplicacion desc,h.id desc')
    Left = 176
    Top = 496
    object QHistoricoID: TIntegerField
      DisplayWidth = 10
      FieldName = 'ID'
    end
    object QHistoricoUSUARIO: TStringField
      DisplayWidth = 50
      FieldName = 'USUARIO'
      Size = 50
    end
    object QHistoricoFECHA_APLICACION: TSQLTimeStampField
      FieldName = 'FECHA_APLICACION'
    end
  end
  object QReset: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'update stock stk set stk.costo_gravado_sombra=0,'
      '                     stk.costo_exento_sombra=0,'
      '                     stk.fecha_act_sombra=null'
      
        'where  (stk.costo_gravado_sombra<>0) or (stk.costo_exento_sombra' +
        '<>0)')
    Left = 280
    Top = 288
  end
