  object QDetalle: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select h.id,h.codigo,h.costo_exento_new,h.costo_exento_old,'
      
        '       h.costo_gravado_new,h.costo_gravado_old,s.detalle_stk as ' +
        'MuestraDetalle from HISTORICO_PRECIO_SOMBRA h'
      'left join stock s on s.codigo_stk=h.codigo'
      'where h.id=:id'
      'order by h.codigo')
    Left = 176
    Top = 552
    ParamData = <
      item
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
