  object QCgeMovCajaOut: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select cm.id_mov_caja , cm.fecha_operacion ,cm.id_comprobante ,c' +
        'm.tipo_comprob,'
      
        '       cm.nro_comprobante,cm.debe,cm.haber,ch.id_cheque_ter,ch.f' +
        'irmante,'
      '       ch.importe from caja_mov cm'
      
        '  left join cheque_tercero ch on ch.id_mov_caja_egresos=cm.id_mo' +
        'v_caja'
      
        'where cm.id_tpago=3 and cm.tipo_operacion='#39'E'#39' and cm.tipo_compro' +
        'b in ('#39'FO'#39','#39'OP'#39','#39'EC'#39','#39'ZI'#39','#39'QT'#39','#39'DP'#39','#39'DA'#39')'
      '      and ch.id_cheque_ter is null')
    Left = 370
    Top = 581
  end
