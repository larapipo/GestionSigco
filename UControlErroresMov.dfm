  object QBorraCajaMov: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'delete from  caja_mov cm where cm.id_mov_caja=:id')
    Left = 611
    Top = 96
    ParamData = <
      item
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
  object QCheMovCaj: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select cm.id_mov_caja , cm.fecha_operacion ,cm.id_comprobante ,c' +
        'm.tipo_comprob,'
      
        '       cm.nro_comprobante,cm.debe,cm.haber,ch.id_cheque_ter,ch.f' +
        'irmante,'
      '       ch.importe from caja_mov cm'
      '  left join cheque_tercero ch on ch.id_mov_caja=cm.id_mov_caja'
      
        'where cm.id_tpago=3 and cm.tipo_operacion='#39'I'#39' and cm.tipo_compro' +
        'b in ('#39'FO'#39','#39'RC'#39','#39'IC'#39','#39'ZI'#39','#39'QT'#39','#39'DP'#39','#39'DA'#39')'
      '      and ch.id_cheque_ter is null')
    Left = 186
    Top = 341
  end
