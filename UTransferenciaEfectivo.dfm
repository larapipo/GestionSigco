  object QTrans: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'Select tc.* ,su.detalle as MuestraSucursal, co.nombre as Muestra' +
        'CajaOrigen, cd.nombre as MuestraCajaDestino,'
      
        ' c.denominacion as MuestraComprobante,c.id_comprobante as Id_Tip' +
        'oComprobante from transferencias_caja tc'
      'left join cuenta_caja co on tc.caja_origen=co.id_cuenta'
      'left join cuenta_caja cd on tc.caja_destino=cd.id_cuenta'
      'left join sucursal su on tc.sucursal=su.codigo'
      'left join comprobantes c on c.clase_comprob=tc.ClaseCpbte and'
      '          c.letra=tc.Letra and'
      '          c.sucursal=tc.sucursal and'
      '          c.tipo_comprob=tc.tipocpbte'
      ''
      'where (tc.Id=:id) and (tc.Tipocpbte=:tipo)')
    Left = 40
    Top = 296
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'tipo'
        DataType = ftString
        ParamType = ptInput
      end>
