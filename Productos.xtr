<XmlTransformation Version="1.0"><Transform Direction="ToCds"><SelectEach dest="DATAPACKET\ROWDATA\ROW" from="\EXPORT\ST_PRODUCTOS\ROW"><Select dest="@COD_ARTICU" from="@COD_ARTICU"/><Select dest="@DESCRIPCION" from="@DESCRIPCION"/><Select dest="@IMPORTE1" from="@IMPORTE1"/><Select dest="@IMPORTE2" from="@IMPORTE2"/></SelectEach></Transform><XmlSchema RootName="EXPORT"><![CDATA[<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="EXPORT" type="EXPORTType"/>
