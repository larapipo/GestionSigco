      <xs:element name="ST_PRODUCTOS" type="ST_PRODUCTOSType"/>
      <xs:element name="PROD_VENDIDOS" type="PROD_VENDIDOSType"/>
    </xs:sequence>
    <xs:attribute name="Fecha" type="xs:string"/>
    <xs:attribute name="Hora" type="xs:string"/>
    <xs:attribute name="Exportado" type="xs:string"/>
    <xs:attribute name="Sucursal" type="xs:string"/>
  </xs:complexType>
  <xs:element name="ST_PRODUCTOS" type="ST_PRODUCTOSType"/>
  <xs:complexType name="ST_PRODUCTOSType">
    <xs:sequence>
      <xs:element name="ROW" type="ROWType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="MODO" type="xs:string"/>
    <xs:attribute name="KEYFIELD" type="xs:string"/>
  </xs:complexType>
  <xs:element name="ROW" type="ROWType"/>
  <xs:complexType name="ROWType">
    <xs:sequence/>
    <xs:attribute name="COD_ARTICU" type="xs:string"/>
    <xs:attribute name="DESCRIPCION" type="xs:string"/>
    <xs:attribute name="IMPORTE1" type="xs:float"/>
    <xs:attribute name="IMPORTE2" type="xs:float"/>
  </xs:complexType>
  <xs:element name="PROD_VENDIDOS" type="PROD_VENDIDOSType"/>
  <xs:complexType name="PROD_VENDIDOSType">
    <xs:sequence>
      <xs:element name="ROW" type="ROWType" minOccurs="0" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="MODO" type="xs:string"/>
    <xs:attribute name="KEYFIELD" type="xs:string"/>
  </xs:complexType>
  <xs:element name="ROW" type="ROWType"/>
  <xs:complexType name="ROWType">
    <xs:sequence/>
    <xs:attribute name="COD_RUBRO" type="xs:string"/>
    <xs:attribute name="RUBRO" type="xs:string"/>
    <xs:attribute name="COD_ARTICU" type="xs:string"/>
    <xs:attribute name="DESCRIPCION" type="xs:string"/>
    <xs:attribute name="UNITARIO" type="xs:string"/>
    <xs:attribute name="CANTIDAD" type="xs:string"/>
  </xs:complexType>
</xs:schema>]]></XmlSchema><CdsSkeleton/><XslTransform/><Skeleton><![CDATA[<?xml version="1.0"?><DATAPACKET Version="2.0"><METADATA><FIELDS><FIELD attrname="COD_ARTICU" fieldtype="string" WIDTH="6"/><FIELD attrname="DESCRIPCION" fieldtype="string" WIDTH="45"/><FIELD attrname="IMPORTE1" fieldtype="r8"/><FIELD attrname="IMPORTE2" fieldtype="r8"/></FIELDS><PARAMS/></METADATA><ROWDATA/><METADATA><FIELDS><FIELD attrname="COD_ARTICU" fieldtype="string" WIDTH="6"/><FIELD attrname="DESCRIPCION" fieldtype="string" WIDTH="45"/><FIELD attrname="IMPORTE1" fieldtype="r8"/><FIELD attrname="IMPORTE2" fieldtype="r8"/></FIELDS><PARAMS/></METADATA><ROWDATA/></DATAPACKET>
