  object QM: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select otm.id,otm.id_otcab,otm.fecha,otm.horainicio,'
      'otm.pruducto,otm.detalle,'
      'p.nombre as Operador,'
      'c.nombre as Cliente from ORDENTRABAJOMov OTM'
      'left join personal p on p.codigo=otm.operario'
      'left join clientes c on c.codigo=otm.cliente'
      'where otm.pruducto=:codigo'
      'order by otm.fecha,otm.horainicio desc')
    Left = 456
    Top = 272
    ParamData = <
      item
        Position = 1
        Name = 'codigo'
        DataType = ftString
        ParamType = ptInput
      end>
  end
