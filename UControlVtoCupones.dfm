  object spVerificaSaldoCupon_old: TSQLStoredProc
    MaxBlobSize = -1
    Params = <>
    SQLConnection = DMMain_2.SQLConectionMain
    StoredProcName = 'TOOLS_VERIFICA_CUPONES'
