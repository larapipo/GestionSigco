  object QCupones: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select ca.*,c.nombre,c.con_planpago,c.cortar_servicio,c.direccio' +
        'n_comercial from cupon_abonos ca'
      'left join clientes c on c.codigo=ca.cliente'
      'where ca.pagado='#39'N'#39' and ( c.activo= :estado or :estado = '#39'*'#39' ) '
      'order by ca.cliente,ca.periodo, ca.fecha_vto2 desc')
    Left = 444
    Top = 402
    ParamData = <
      item
        Position = 1
        Name = 'estado'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'estado'
        DataType = ftString
        ParamType = ptInput
      end>
  end
