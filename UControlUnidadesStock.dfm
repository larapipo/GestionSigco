  object QStock: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select s.codigo_stk,s.detalle_stk,s.unidad,s.unidad_compra,'
      
        '       s.contenido_compra,s.presentacion_cantidad,s.presentacion' +
        '_unidad, s.iva_modificado,s.plu,s.dias_vencimiento from stock s'
      'where (s.marca_stk = :marca or :marca = '#39'****'#39' ) and'
      '      (s.rubro_stk = :rubro or :rubro = '#39'***'#39' ) and'
      '      (s.subrubro_stk = :subrubro or :subrubro = '#39'*****'#39' )')
