  object QNC: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select D.codigoarticulo,s.detalle_stk,'
      '       s.marca_stk,s.rubro_stk,s.subrubro_stk,'
      '       m.descripcion_marca as MuestraMarca,'
      '       r.detalle_rubro as MuestraRubo,'
      '       sr.detalle_subrubro as MuestraSubRubro,'
      '       sum(D.costo_total*D.Cantidad) as Costo,'
      
        '       sum(D.Unitario_total*D.Cantidad) as Unitario,sum(d.total)' +
        ' as Facturado,'
      '       sum(d.cantidad) as Cantidad'
      'from fcvtadet D'
      'left join fcvtacab c on c.id_fc=d.id_cabfac'
      'left join stock s on s.codigo_stk=d.codigoarticulo'
      'left join marcas m on m.marca_stk=s.marca_stk'
      'left join rubros r on r.codigo_rubro=s.rubro_stk'
      'left join subrubros sr on sr.codigo_subrubro=s.subrubro_stk'
      'where D.tipocpbte<>'#39'NC'#39' and D.fechavta between :desde and :hasta'
      '   and c.anulado='#39'N'#39
      'group by D.codigoarticulo,'
      '       s.detalle_stk,s.marca_stk,s.rubro_stk,s.subrubro_stk,'
      '       m.descripcion_marca,r.detalle_rubro,sr.detalle_subrubro'
      ' '
      ' ')
    Left = 88
    Top = 240
    ParamData = <
      item
        Position = 1
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end>
  end
