  object QVentas: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select d.codigoarticulo,c.tipocpbte,s.detalle_stk,'
      '       s.marca_stk,s.rubro_stk,s.subrubro_stk,'
      '       m.descripcion_marca as MuestraMarca,'
      '       r.detalle_rubro as MuestraRubo,'
      '       sr.detalle_subrubro as MuestraSubRubro,'
      '       sum(D.costo_total*D.Cantidad) as Costo,'
      
        '       sum(D.Unitario_total * D.Cantidad * (1- (d.descuento*0.01' +
        ') )) as Unitario,'
      '       sum(d.total) as Facturado,'
      '       sum(d.cantidad) as Cantidad'
      'from fcvtacab c'
      'left join fcvtadet d on d.id_cabfac=c.id_fc'
      'left join stock s on s.codigo_stk=d.codigoarticulo'
      'left join marcas m on m.marca_stk=s.marca_stk'
      'left join rubros r on r.codigo_rubro=s.rubro_stk'
      'left join subrubros sr on sr.codigo_subrubro=s.subrubro_stk'
      
        'where  (c.fechavta between :desde and :hasta) and (c.sucursal= :' +
        'sucursal or :sucursal=-1)'
      
        '   and c.anulado='#39'N'#39' AND ( S.controlastock = :control or :contro' +
        'l = '#39'*'#39')'
      'group by D.codigoarticulo,c.tipocpbte,s.detalle_stk,'
      '         s.marca_stk,s.rubro_stk,s.subrubro_stk,'
      '         m.descripcion_marca,r.detalle_rubro,sr.detalle_subrubro'
      ' ')
    Left = 88
    Top = 128
    ParamData = <
      item
        Position = 1
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
        Value = Null
      end
      item
        Position = 2
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'SUCURSAL'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'control'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object QDetalle: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select  d.codigoarticulo, d.id_cabfac,d.tipocpbte,d.nrocpbte,d.f' +
        'echavta,d.cantidad,'
      
        '       d.costo_total,d.unitario_total,d.total,d.unitario_total-d' +
        '.costo_total as Diferencia from fcvtadet d'
      'join fcvtacab c on c.id_fc=d.id_cabfac and c.anulado='#39'N'#39
      'where d.id_cabfac>= :Iddesde and d.id_cabfac<= :Idhasta '
      'order by d.codigoarticulo,d.id_cabfac,d.tipocpbte,d.nrocpbte')
    Left = 88
    Top = 184
    ParamData = <
      item
        Name = 'IDDESDE'
        DataType = ftInteger
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'IDHASTA'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
