  object QBuscador: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select o.id_ot,o.tipocpbte,o.clasecpbte, o.nrocpbte,o.nombre,o.i' +
        'dentificadorproducto,o.descripcionproducto from ordentrabajocab ' +
        'o'
      
        'where (o.identificadorproducto containing :dato ) or (o.descripc' +
        'ionproducto containing :dato )')
    Left = 72
    Top = 320
    ParamData = <
      item
        Position = 1
        Name = 'dato'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'dato'
        DataType = ftString
        ParamType = ptInput
      end>
  end
