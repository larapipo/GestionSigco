  object QFacVta: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select f.id_fc,f.fechavta,f.tipocpbte,f.clasecpbte,f.nrocpbte,f.' +
        'codigo,f.fecha_liquidacion,'
      'f.nombre,f.COMSIONVENDEDOR,'
      'case when f.tipocpbte='#39'NC'#39' then (f.netograv2+f.netoexen2)*-1'
      '     when f.tipocpbte<>'#39'NC'#39' then (f.netograv2+f.netoexen2)'
      'end as Total,     '
      ''
      'f.liquidada,mcc.saldo,'
      'case when f.tipocpbte='#39'NC'#39' then (f.total)*-1'
      '     when f.tipocpbte<>'#39'NC'#39' then (f.total)'
      'end as TotalFC,     '
      'cl.cobrador from FcVtaCab f'
      
        'left join movccvta mcc on mcc.id_cpbte=f.id_fc and mcc.tipocpbte' +
        '=f.tipocpbte'
      'left join clientes cl on cl.codigo = f.codigo'
      
        'where f.vendedor=:codigo and f.fechavta between :desde and :hast' +
        'a'
      
        '       and f.anulado<>'#39'S'#39' and (f.liquidada = :Liq or f.liquidada' +
        ' is null or :Liq = '#39'*'#39' )'
      '       and (f.tipocpbte = :tipo or :tipo = '#39'**'#39' )'
      'order by'
      'f.fechavta,f.tipocpbte,f.nrocpbte')
    Left = 131
    Top = 115
    ParamData = <
      item
        Position = 1
        Name = 'codigo'
        DataType = ftString
        ParamType = ptInput
        Value = Null
      end
      item
        Position = 2
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 4
        Name = 'Liq'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 6
        Name = 'tipo'
        DataType = ftString
        ParamType = ptInput
      end>
    object QFacVtaID_FC: TIntegerField
      FieldName = 'ID_FC'
      Origin = 'ID_FC'
      ProviderFlags = [pfInUpdate, pfInWhere, pfInKey]
      Required = True
    end
    object QFacVtaFECHAVTA: TSQLTimeStampField
      FieldName = 'FECHAVTA'
      Origin = 'FECHAVTA'
