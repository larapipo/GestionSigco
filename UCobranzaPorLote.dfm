  object QFacturas: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        ' select c.id_fc,c.codigo,c.razonsocial,c.nombre,c.nrocpbte,c.tip' +
        'ocpbte, c.clasecpbte,c.total,'
      '        c.vendedor,p.nombre as MuestraVdor,'
      '        m.saldo from fcvtacab c'
      
        '   left join movccvta m on m.id_cpbte=c.id_fc and m.tipocpbte=c.' +
        'tipocpbte'
      '   left join personal p on p.codigo=c.vendedor'
      
        'where (c.tipocpbte='#39'FC'#39' or c.tipocpbte='#39'ND'#39') and ( c.fechavta be' +
        'tween :desde and :hasta ) and m.saldo>0')
    Left = 48
    Top = 80
    ParamData = <
      item
        Position = 1
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end>
    object QFacturasID_FC: TIntegerField
      FieldName = 'ID_FC'
      Origin = 'ID_FC'
      ProviderFlags = [pfInUpdate, pfInWhere, pfInKey]
      Required = True
