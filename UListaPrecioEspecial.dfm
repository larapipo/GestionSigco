  object QListaArt_: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select la.* ,'
      '  s.detalle_stk as MuestraArticulo,'
      '  s.Costo_gravado_sombra as MuestaGravadoSombra,'
      '  s.Costo_exento_sombra as MuestraExentoSombra,'
      '  sta.tasa as muestrasobretasa,'
      '  s.marca_stk as MuestraMarca,'
      '  m.descripcion_marca as MuestraDescMarca,'
      '  s.contenido_compra as MuestraContenido,'
      '  s.modo_gravamen as MuestraModoGravamen,'
      '  md.signo as MuestraSignoM,'
      '  s.fuap as MuestraFActualizacion,'
      '  s.fecha_alta as MuestraFAlta,'
      '  s.clase_articulo as MuestraClaseArt,'
      '  s.modo_iva'
      'from listaprecioespecialart la'
      'left join stock s on s.codigo_stk=la.codigoarticulo'
      'left join marcas m on m.marca_stk=s.marca_stk'
      'left join gravamen ta on s.tasa_iva=ta.codigo'
      'left join gravamen Sta on s.Sobretasa_iva=Sta.codigo'
      'left join monedas md on md.id=s.moneda'
      'where la.id_cab=:id AND s.CLASE_ARTICULO IN (1,3) ')
