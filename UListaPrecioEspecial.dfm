  object QListaCab_: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select l.*,fp.detalle as MuestraFormaPago from listaprecioespeci' +
        'alcab l '
      'left join f_pago fp on fp.codigo=l.f_pago'
      'where l.id=:id')
