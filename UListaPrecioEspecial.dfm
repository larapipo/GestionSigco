    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select ls.rubro,ls.subrubro,ls.recargo,ls.id,ls.id_cab,'
      
        'sr.detalle_subrubro as MuestraSubRubro,ls.descuento,ls.rec_aplic' +
        'ar from listaprecioespecialsub ls'
      'left join subrubros sr on ls.subrubro=sr.codigo_subrubro'
