  object QListaRub_: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select  lr.rubro,lr.recargo,lr.id,lr.id_cab, r.detalle_rubro as ' +
        'MuestraRubro,lr.descuento,lr.rec_aplicar'
      'from listaprecioespecialrub lr'
      'left join rubros r on r.codigo_rubro=lr.rubro'
      'where lr.id_cab=:id'
      'order by lr.rubro')
