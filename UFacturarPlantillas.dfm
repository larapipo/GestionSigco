  object QActualizaSaldo: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'update reg_fact_plantillas rg set rg.saldo_cc='
      '  (select sum(m.saldo) from  movccvta m'
      '    left join fcvtacab f on f.id_fc=m.id_cpbte'
      
        '   where m.cliente= rg.cliente and m.saldo>0 and (f.tipo_vta = :' +
        'tipovta or :tipovta = '#39'*'#39' ) and m.fechavta<= :fecha ) where rg.i' +
        'd_fac=:id')
    Left = 976
    Top = 88
    ParamData = <
      item
        Name = 'tipovta'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'tipovta'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'fecha'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
