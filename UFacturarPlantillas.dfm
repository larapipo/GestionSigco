  object QPlantillas: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.codigo,c.nombre as MuestraNombre,'
      '  c.id_facturapordefecto,'
      '  c.tipoabono,c.mes_abonoanual,c.mes_semestral,'
      '  cp.denominacion as MuestraComprobante,'
      '  c.id_plantilla,pla_cab.detalle as MuestraPlantilla,'
      
        '  c.vendedor,c.zona,c.mes_adicional,c.con_hosting,c.cobrador,c.p' +
        'lantilla_civa,pe.nombre as NombreCobrador'
      'from clientes c'
      '  left join plantillas_cab pla_cab on pla_cab.id=c.id_plantilla'
      
        '  left join comprobantes cp on cp.id_comprobante=c.id_facturapor' +
        'defecto'
      '  left join personal pe on pe.codigo=c.cobrador'
      
        'where ((c.id_plantilla = :plantilla) or (:plantilla = -1 )) and ' +
        '((c.sucursal = :sucursal) or (:sucursal <= 0 )) and'
      
        '      c.activo='#39'S'#39' and ( c.tipoabono = '#39'M'#39' or c.tipoabono = '#39'A'#39' ' +
        'or  c.tipoabono = '#39'S'#39' )'
      
        'and c.fecha_incio_fc_abono <= :FechaFacturacion and ( c.vendedor' +
        ' = :vendedor or :vendedor = '#39'******'#39' )'
      'order by c.codigo')
    Left = 304
    Top = 336
    ParamData = <
      item
        Name = 'plantilla'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'plantilla'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'FechaFacturacion'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'vendedor'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'vendedor'
        DataType = ftString
        ParamType = ptInput
      end>
