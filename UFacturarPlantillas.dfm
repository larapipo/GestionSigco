  object QPlantillasNo: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select pc.codigo,c.nombre as MuestraNombre,'
      '  c.id_facturapordefecto,'
      '  c.tipoabono,c.mes_abonoanual,'
      '  cp.denominacion as MuestraComprobante,'
      '  pc.id,pla_cab.detalle as MuestraPlantilla,'
      '  c.vendedor,c.zona,c.mes_adicional,c.con_hosting'
      'from plantillas_clientes pc'
      '  left join clientes c on c.codigo=pc.codigo'
      '  left join plantillas_cab pla_cab on pla_cab.id=pc.id'
      
        '  left join comprobantes cp on cp.id_comprobante=c.id_facturapor' +
        'defecto'
      'where pc.id = :plantilla and c.sucursal= :sucursal and'
      
        '      ( c.tipoabono = '#39'M'#39' or c.tipoabono = '#39'A'#39' or  c.tipoabono =' +
        ' '#39'S'#39' or  c.tipoabono = '#39#39' )'
      
        'and c.fecha_incio_fc_abono > :FechaFacturacion and ( c.vendedor ' +
        '= :vendedor or :vendedor = '#39'******'#39' )'
      'order by pc.codigo'
      ''
      '')
