  object QRegFacturas: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select r.*,c.nombre as MuestraNombre,c.direccion_comercial as Mu' +
        'estraDireccion,'
      
        '  c.cobrador,p.nombre as MuestraCobrador,C.direccion_postal AS M' +
        'uestraDireccionPostal,'
      
        '  c.calle_1 as MuestraCalle1,c.calle_2 as MuestraCalle2,c.zona,z' +
        '.detalle as MuestraZona from reg_fact_plantillas r'
      'left join clientes c on c.codigo=r.cliente'
      'left join personal p on p.codigo=c.cobrador'
      'left join zona z on z.id_zona=c.zona'
      'where r.lote = :lote '
      'order by r.nrocpbte')
    Left = 720
    Top = 152
    ParamData = <
      item
        Name = 'lote'
        DataType = ftInteger
        ParamType = ptInput
      end>
