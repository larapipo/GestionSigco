  object QSuperCCC: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select  tm.codigocliente,'
      '        c.nombre,'
      '        tm.codigoarticulo,'
      '        s.detalle_stk,'
      '        sum(tm.saldo_acreedor) as saldo_acreedor,'
      '        sum(tm.saldo_deudor)as saldo_deudor,'
      '        sum(tm.saldo_devoluciones)as saldo_devoluciones,'
      
        '       sum((COALESCE(tm.saldo_acreedor,0) + COALESCE(tm.saldo_de' +
        'voluciones,0) - COALESCE(tm.saldo_deudor,0)) *lp.precio) as sald' +
        'oValorizado'
      'from tabla_ccc_cant tm'
      'left join clientes c on c.codigo=tm.codigocliente'
      'left join stock s on s.codigo_stk=tm.codigoarticulo'
      
        'left join listaprecioespecialart lp on lp.codigoarticulo=tm.codi' +
        'goarticulo'
      'where lp.id_cab= :idListaPrecio'
      
        'group by tm.codigocliente,c.nombre,tm.codigoarticulo,s.detalle_s' +
        'tk'
      '--order by tm.codigocliente')
    Left = 716
    Top = 352
    ParamData = <
      item
        Position = 1
        Name = 'IDLISTAPRECIO'
        DataType = ftInteger
        ParamType = ptInput
      end>
    object QSuperCCCCODIGOCLIENTE: TStringField
      FieldName = 'CODIGOCLIENTE'
      Origin = 'CODIGOCLIENTE'
      Size = 6
    end
    object QSuperCCCNOMBRE: TStringField
      AutoGenerateValue = arDefault
      FieldName = 'NOMBRE'
      Origin = 'NOMBRE'
      ProviderFlags = []
      ReadOnly = True
      Size = 35
    end
    object QSuperCCCCODIGOARTICULO: TStringField
      FieldName = 'CODIGOARTICULO'
      Origin = 'CODIGOARTICULO'
      Size = 8
    end
