  object QDeduaAcopio: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.cliente,c.nombre,'
      
        '  sum (c.acopio) as acopio,sum ( c.entrega ) as entregas , sum (' +
        ' c.devolucion ) as devolucion,'
      
        '  ( sum (c.acopio) - sum ( c.entrega ) - sum ( c.devolucion )) a' +
        's SAldo  from cta_acopios c'
      'group by c.cliente,c.nombre')
    Left = 168
    Top = 208
  end
