  object QMercDet: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select  s.codigo_stk as codigo_stk,'
      '        s.detalle_stk as detalle_stk,'
      
        '        COALESCE(qb.saldoPendiente,0) +COALESCE(qc.faltaEntregar' +
        ',0) as saldo_acreedor,'
      '        COALESCE(qa.entregadoSinFacturar,0) as saldo_deudor,'
      '        COALESCE(qd.devolucion,0) as devolucion,'
      
        '        COALESCE(qb.saldoPendiente,0) +COALESCE(qc.faltaEntregar' +
        ',0)+ COALESCE(qd.devolucion,0) - COALESCE(qa.entregadoSinFactura' +
        'r,0) as saldo_total,'
      
        '        (COALESCE(qb.saldoPendiente,0) +COALESCE(qc.faltaEntrega' +
        'r,0)+ COALESCE(qd.devolucion,0) - COALESCE(qa.entregadoSinFactur' +
        'ar,0)) *lp.precio as saldoValorizado'
      ''
      ''
      'from stock s'
      ''
      'left join'
      '            (select  rd.codigoarticulo as codigoSRTO,'
      '            sum(rd.cantidad) as entregadoSinFacturar'
      ''
      '            from rtodet rd'
      '            left join rtocab rc on rd.id_cabrto=rc.id_rto'
      ''
      
        '             where (rc.anulado ='#39'N'#39' and rc.devolucion ='#39'N'#39' and  ' +
        '((rc.idfactura is null) or (rc.idfactura<=0) )  and ( rd.CANT_FA' +
        'CTURA>0 or  rd.CANT_FACTURA<0))'
      
        '            group by rd.codigoarticulo) as qa on qa.codigoSRTO =' +
        's.codigo_stk'
      ''
      'left  join'
      '            (select md.codigo as codigoMerca,'
      '            sum(md.saldo) as saldoPendiente'
      '            from  merca_enacopio_det md'
      '            left join merca_enacopio_cab mc on mc.id=md.id_cab'
      ''
      '            where mc.cumplido<>'#39'S'#39' AND md.saldo > 0'
      
        '            group by md.codigo) as qb on qb.codigoMerca = s.codi' +
        'go_stk'
      ''
      'left  join'
      '            (select npd.codigoarticulo as npcodigoart,'
      '            sum(npd.cantidad_faltante) as faltaEntregar'
      '            from  npedidodet_cliente npd'
      
        '            left join  npedidocab_cliente npc on npc.id=npd.id_c' +
        'abnp'
      ''
      
        '            where(npc.factura_id IS NOT NULL) AND (npc.factura_i' +
        'd > 0) AND npc.estado IN ('#39'P'#39','#39'N'#39')'
      
        '            group by npd.codigoarticulo) as qc on qc.npcodigoart' +
        '= s.codigo_stk'
      ''
      'left join'
      '            (select rd.codigoarticulo as codigoArticulo,'
      '            sum(rd.cantidad) as devolucion'
      ''
      '            from rtodet rd'
      '            left join rtocab rc on rd.id_cabrto=rc.id_rto'
      ''
      ''
      
        '            where rc.anulado='#39'N'#39' and rc.devolucion='#39'S'#39' and  ((rc' +
        '.idfactura is null) or (rc.idfactura<=0) )  and ( rd.CANT_FACTUR' +
        'A>0 or  rd.CANT_FACTURA<0)'
      '            group by rd.codigoarticulo, rc.codigo'
      '            ) as qd on qd.codigoArticulo=s.codigo_stk'
      ''
      
        'left join listaprecioespecialart lp on lp.codigoarticulo=s.codig' +
        'o_stk'
      ''
      'where (s.clase_articulo in(1,3))and  (lp.id_cab= :idListaPrecio)'
      'order by s.codigo_stk')
    Left = 32
    Top = 416
    ParamData = <
      item
        Position = 1
        Name = 'IDLISTAPRECIO'
        DataType = ftInteger
        ParamType = ptInput
      end>
