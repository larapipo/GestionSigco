  object QBuscaCaja: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select ca.*, cta.Nombre as MuestraCaja from Caja_Cab ca '
      'inner join cuenta_caja cta on cta.id_cuenta=ca.id_cuenta_caja '
      'where ca.Estado=0')
