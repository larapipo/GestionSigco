  object QChe3: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select ch.*,bco.nombre as MuestraBanco from cheque_tercero ch'
      'left join bancos bco on bco.id_banco=ch.id_banco'
      'where ch.id_cuenta_caja=:id_cuenta_caja and disponible='#39'S'#39
      'order by ch.numero')
