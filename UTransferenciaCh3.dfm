  object QMov: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select m.*, cta.nombre as MuestraCaja,caja.numerocaja,'
      'case caja.estado when 0 then '#39'Abierta'#39
      '                 when 1 then '#39'Cerrada'#39
      '                 else '#39'Sin Estado'#39
      '                 end as Estado  from caja_mov m'
      'left join cuenta_caja cta on cta.id_cuenta=m.id_cuenta_caja'
      'left join caja_cab caja on caja.id_caja=m.id_caja'
      'where m.tipo_comprob=:tipo and m.id_comprobante=:id ')
    Left = 56
    Top = 560
    ParamData = <
      item
        Position = 1
        Name = 'tipo'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
