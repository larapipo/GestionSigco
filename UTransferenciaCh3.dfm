  object QTransDetalle: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'Select td.*,coalesce(ch.e_check,'#39#39') as e_check, bco.nombre as Mu' +
        'estraBanco from TRANSFERENCIAS_CAJA_DETALLE td'
      'join bancos bco on bco.id_banco=td.id_banco'
      'left join cheque_tercero ch on ch.id_cheque_ter=td.id_cheque'
      'where td.id_transferencia=:id')
