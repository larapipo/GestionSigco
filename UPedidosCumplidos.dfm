  object QPedido: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select n.* from npedidocab_cliente n'
      
        'where n.estado='#39'N'#39' and ((n.ENTREGA_ID_CPBTE is null) or (n.ENTRE' +
        'GA_ID_CPBTE <= 0 ))'
      'order by n.razonsocial')
    Left = 240
    Top = 264
  end
