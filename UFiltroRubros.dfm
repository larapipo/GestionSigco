  object QRubros: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select r.codigo_rubro, r.detalle_rubro from rubros r'
      'order by r.detalle_rubro')
    Left = 200
    Top = 328
  end
