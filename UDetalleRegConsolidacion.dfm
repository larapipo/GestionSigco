  object QRegAjuste: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select r.*,c.nombre from REG_CONSOLIDA_CTAS r'
      'left join clientes c on c.codigo=r.cta_origen'
      'where  r.id_ajuste_destino = :id')
    Left = 128
    Top = 280
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
