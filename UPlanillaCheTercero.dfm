  object QChe3: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select ch.id_mov_caja, bc.nombre as MuestraBanco,ch.numero, ch.F' +
        'echa_Emision,'
      
        'ch.Fecha_Cobro,ch.Fecha_Entrada,ch.Fecha_Salida, ch.Origen, ch.d' +
        'estino,'
      
        'ch.importe, ch.saldo_importe, ch.disponible, ch.firmante, ch.id_' +
        'cuenta_caja,'
      'cc.Nombre as MuestraCtaCaja,'
      'ch.sucursal_bco,ch.nro_cta,ch.cuit,'
      
        'cc_e.nombre as MuestraBanco_echeck,cc_e.nro_cuenta as MuestraNro' +
        'Cta_echeck,ch.e_check,'
      'c.denominacion,m.tipo_comprob,m.clase_comprob,m.nro_comprobante'
      ''
      'from cheque_tercero ch'
      'left join bancos bc on bc.id_banco = ch.id_banco'
      'left join cuenta_caja cc on cc.id_cuenta= ch.id_cuenta_caja'
      'left join cuenta_caja cc_e on cc_e.id_cuenta= ch.id_cta_caja_bco'
      ''
      'left join caja_mov m on m.id_mov_caja=ch.id_mov_caja'
      'left join tipo_comprobante tc on tc.sigla=m.tipo_comprob'
      'left join comprobantes c on c.tipo_comprob =m.tipo_comprob and'
      '                            c.clase_comprob=m.clase_comprob and'
      ''
      
        'c.letra= (case when m.tipo_comprob = '#39'RC'#39' then (select r.letrarc' +
        ' from recibos r where r.id_rc=m.id_comprobante)'
      
        '           when m.tipo_comprob = '#39'FO'#39' then (select fc.letrafac f' +
        'rom fcvtacab fc where fc.id_fc=m.id_comprobante)'
      
        '           when m.tipo_comprob = '#39'IC'#39' then (select ing.letra fro' +
        'm ing_caja ing where ing.id_ingreso=m.id_comprobante)'
      '         end)'
      '  and'
      
        'c.sucursal = (case when m.tipo_comprob = '#39'RC'#39' then (select r.suc' +
        'ursal from recibos r where r.id_rc=m.id_comprobante)'
      
        '               when m.tipo_comprob = '#39'FO'#39' then (select fc.sucurs' +
        'al from fcvtacab fc where fc.id_fc=m.id_comprobante)'
      
        '               when m.tipo_comprob = '#39'IC'#39' then (select ing.sucur' +
        'salventa from ing_caja ing where ing.id_ingreso=m.id_comprobante' +
        ')'
      '             end)'
      ''
      'where ch.disponible='#39'S'#39
      'order by ch.id_cuenta_caja,ch.fecha_Cobro')
    Left = 93
    Top = 97
  end
