  object QAjustes: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select a.*, c.nombre as MuestraNombre,'
      '  c.razon_social as MuestraRazonSocial,'
      '  s.detalle as MuestraSucursal,'
      '  cp.denominacion as MuestraComprobante,'
      '  cp.id_comprobante as id_tipocomprobante,'
      '  mcc.id as MuestraIdMovCC,'
      
        '  cm.id_caja as MuestraIdCaja,cm.tipo_comprob as MustraTipoCompC' +
        'aja,cm.nro_comprobante as MuestraNroCompCaja,cm.id_comprobante a' +
        's MuestraIdCompCaja,'
      
        '  fc.tipocpbte as MuestraTipoConsolidada, fc.nrocpbte as Muestra' +
        'NroConsolidada,'
      
        '  fcc.tipocpbte as MuestraTipoFcCuotas, fcc.nrocpbte as MuestraF' +
        'cNroCuotas from ajuste_cc_clientes a'
      'left join clientes c on c.codigo=a.codigo'
      'left join sucursal s on s.codigo=a.sucursal'
      'left join mov_caja_ctacte mcc on mcc.id_ajuste_cc=a.id'
      'left join caja_mov cm on cm.id_mov_caja= mcc.id_mov_caja'
      'left join fcvtacab fc on fc.id_fc=a.id_factura_consolidada'
      'left join fcvtacab fcc on fcc.id_fc=a.id_fc_cuotas'
      'left join comprobantes cp on cp.clase_comprob=a.ClaseCpbte and'
      '          cp.letra=a.Letra and'
      '          cp.sucursal=a.sucursal and'
      '          cp.tipo_comprob=a.tipocpbte and'
      '          cp.compra_venta='#39'V'#39
      'where a.id=:id')
    Left = 152
    Top = 224
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
