  object QRtos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select r.id_rto,r.fechavta,r.nrocpbte,r.total from rtocab r'
      
        'where r.codigo=:codigo and ((r.idfactura is null) or (r.idfactur' +
        'a<=0)) and (r.anulado='#39'N'#39')')
    Left = 740
    Top = 211
    ParamData = <
