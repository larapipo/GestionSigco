  object qChe3: TFDQuery
    MasterSource = DMMain_2.DSPrecioXCant
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select ch.id_banco,ch.fecha_cobro,ch.fecha_emision,ch.fecha_entr' +
        'ada,'
      'ch.fecha_salida,ch.firmante,ch.unidades,ch.importe,ch.numero,'
      
        'ch.destino,ch.origen,b.nombre as MuestraBco from cheque_tercero ' +
        'ch'
      'left join bancos b on b.id_banco=ch.id_banco'
      'where ch.id_cheque_ter=:id')
    Left = 184
    Top = 280
    ParamData = <
      item
        Name = 'ID'
        DataType = ftInteger
        ParamType = ptInput
        Value = Null
      end>
