  object QFacVta: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select fcc.id_fc,fcc.fechavta,fcc.tipocpbte,fcc.clasecpbte,fcc.n' +
        'rocpbte,fcc.Fecha_liquidacion,'
      'fcc.codigo,fcc.nombre,fcc.liquidada,'
      
        'fcd.codigoarticulo,fcd.detalle,fcd.cantidad,fcd.total*((100-fcc.' +
        'dsto)* 0.01) as Total,mcc.saldo as MuestraSaldo,'
      'c.comision,fcd.costo_total as CostoTotal,'
      '(fcd.total*((100-fcc.dsto)* 0.01) - fcd.costo_total) as DifVta,'
      'fcd.Total+fcd.iva_total as Total_Final,fcd.iva_total,'
      'cl.zona from FcVtaCab fcc'
      'left join Clientes cl on cl.codigo=fcc.codigo'
      'left join fcvtadet fcd on fcd.id_cabfac = fcc.id_fc'
      'left join personal p on p.codigo = fcc.vendedor'
      'left join personal p2 on p2.codigo = cl.cobrador'
      
        'left join comisionesart c on c.codigoarticulo=fcd.codigoarticulo' +
        ' and c.id_cab=p.politicacomision'
      
        'left join movccvta mcc on mcc.id_cpbte = fcc.id_fc and mcc.tipoc' +
        'pbte=fcc.tipocpbte'
      
        'where fcc.vendedor=:codigo and ( cl.cobrador = :cobrador or :cob' +
        'rador = '#39'******'#39' ) and'
      'fcc.fechavta between :desde and :hasta and'
      'fcc.anulado<>'#39'S'#39
      'and (fcc.liquidada='#39'N'#39' or fcc.liquidada is null) and fcd.total>0'
      'order by'
      'fcc.fechavta,fcc.tipocpbte,fcc.nrocpbte')
    Left = 36
    Top = 201
    ParamData = <
      item
        Position = 1
        Name = 'codigo'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'cobrador'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'cobrador'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 4
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 5
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end>
  end
  object QFacVtaAnt: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select fcc.id_fc,fcc.fechavta,fcc.tipocpbte,fcc.clasecpbte,fcc.n' +
        'rocpbte,fcc.Fecha_liquidacion,'
      'fcc.codigo,fcc.nombre,fcc.liquidada,'
      'fcd.codigoarticulo,fcd.detalle,fcd.cantidad,'
      
        'fcd.total*((100-fcc.dsto)* 0.01) as Total,mcc.saldo as MuestraSa' +
        'ldo,'
      'c.comision,fcd.iva_total from FcVtaCab fcc'
      'left join fcvtadet fcd on fcd.id_cabfac=fcc.id_fc'
      'left join personal p on p.codigo=fcc.vendedor'
      
        'left join comisionesart c on c.codigoarticulo=fcd.codigoarticulo' +
        ' and c.id_cab=p.politicacomision'
      
        'left join movccvta mcc on mcc.id_cpbte=fcc.id_fc and mcc.tipocpb' +
        'te=fcc.tipocpbte'
      'where fcc.vendedor=:codigo and'
      'fcc.fechavta between :desde and :hasta and'
      'fcc.anulado<>'#39'S'#39
      'and (fcc.liquidada='#39'N'#39' or fcc.liquidada is null) and fcd.total>0'
      'order by'
      'fcc.fechavta,fcc.tipocpbte,fcc.nrocpbte')
    Left = 44
    Top = 257
    ParamData = <
      item
        Position = 1
        Name = 'codigo'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end>
  end
