  object QStock: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select  d.codigoarticulo,d.detalle,d.unitario_exento,d.unitario_' +
        'gravado,'
      
        '        d.unitario_total,d.codigoproveedor,c.nombre,d.fechacompr' +
        'a from fccompdet d'
      'left join fccompcab c on c.id_fc=d.id_cabfac'
      
        'where ( d.codigoarticulo = :CodArticulo ) and ( d.fechacompra be' +
        'tween :desde and :hasta )'
      'order by d.codigoproveedor,d.fechacompra desc')
