  object QMov: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select d.codigoarticulo,d.codigoproveedor,d.detalle,c.nombre,'
      
        '       d.unitario_exento,d.unitario_gravado,d.unitario_total,(d.' +
        'fechacompra) from fccompdet d'
      'left join fccompcab c on c.id_fc=d.id_cabfac'
      'left join stock s on s.codigo_stk=d.codigoarticulo'
      
        'where ( d.codigoarticulo = :CodArticulo or :CodArticulo = '#39'*****' +
        '***'#39' ) and'
      '      ( d.fechacompra between :desde and :hasta ) and'
      
        '      ( s.clase_articulo in (1,3,2) ) and (s.controlastock = :co' +
        'ntrolaStk or :controlaStk = '#39'*'#39')'
      
        'group by d.codigoarticulo,d.codigoproveedor,d.detalle,c.nombre,d' +
        '.unitario_exento,d.unitario_gravado,'
      '        d.unitario_total,d.fechacompra'
      'order by d.codigoarticulo,d.codigoproveedor, d.fechacompra desc')
    Left = 208
    Top = 464
    ParamData = <
      item
        Position = 1
        Name = 'CodArticulo'
        DataType = ftString
        ParamType = ptInput
        Value = Null
      end
      item
        Position = 3
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 4
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 5
        Name = 'controlaStk'
        DataType = ftString
        ParamType = ptInput
      end>
  end
