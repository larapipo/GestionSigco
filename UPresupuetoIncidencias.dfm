  object QIncidencias: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select i.*,p.codigo from PRES_Incidencias i '
      'left join prescab p on p.id_pr= i.id_presupuesto'
      'where i.ID_PRESUPUESTO = :ID '
      'order by i.fecha_hora asc')
    Left = 344
    Top = 368
    ParamData = <
      item
        Position = 1
        Name = 'ID'
        DataType = ftInteger
        ParamType = ptInput
      end>
