  object QStockExistencia: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select sum(ds.fisico) as Fisico ,sum(ds.minimo) as Minimo from d' +
        'epositostk ds '
      'left join depositos d on d.id=ds.codigo_deposito'
      'where ds.codigo_Stk=:codigo  and d.centraliza_stock='#39'S'#39)
    Left = 888
    Top = 224
    ParamData = <
      item
        Name = 'CODIGO'
        DataType = ftString
        ParamType = ptInput
        Size = 8
        Value = Null
      end>
    object QStockExistenciaFISICO: TFloatField
      AutoGenerateValue = arDefault
      FieldName = 'FISICO'
