  object QFcCompDet: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select d.*, s.rubro_stk as rubro, s.subrubro_stk as subrubro, s.' +
        'marca_stk, '
      
        '       r.detalle_rubro as MuestraRubro, sr.detalle_subrubro as M' +
        'uestraSubrubro, '
      '       m.descripcion_marca as MuestraMarca '
      'from fccompdet d'
      'left join stock s on s.codigo_stk=d.codigoarticulo'
      'left join rubros r on r.codigo_rubro=s.rubro_stk'
      'left join subrubros sr on sr.codigo_subrubro =s.subrubro_stk'
      'left join marcas m on m.marca_stk=s.marca_stk'
      'where d.id=:id')
    Left = 80
    Top = 192
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
