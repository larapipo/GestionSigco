  object DSConsulta: TDataSource
    DataSet = QConsulta
    Left = 496
    Top = 136
  end
  object QConsulta: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select d.tipocpbte,d.nrocpbte,d.fechavta,d.codigoarticulo,d.deta' +
        'lle,d.unitario_total,d.costo_total,'
      '          c.razonsocial,c.codigo,d.id_cabfac from FcVtaDet D'
      'left join FcVtaCab C on c.id_fc= d.id_cabFac'
      'where d.tipocpbte in ('#39'FO'#39','#39'FC'#39')'
      'order By d.fechavta desc,d.Detalle')
    Left = 416
    Top = 136
