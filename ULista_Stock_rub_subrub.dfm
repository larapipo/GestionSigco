  object QControlRubSubStock_: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select s.codigo_stk,s.detalle_stk,s.rubro_stk,s.subrubro_stk,r.d' +
        'etalle_rubro,sr.detalle_subrubro from stock s'
      'left join rubros r on r.codigo_rubro=s.rubro_stk'
      'left join subrubros sr on sr.codigo_subrubro=s.subrubro_stk'
      'order by s.detalle_stk')
    Left = 44
    Top = 416
