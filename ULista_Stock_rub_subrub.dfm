  object QStock: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select s.codigo_stk,s.detalle_stk||'#39' ('#39'||  coalesce( m.descripci' +
        'on_marca,'#39#39') ||'#39')'#39' as Detalle_stk,s.rubro_stk,s.subrubro_stk fro' +
        'm stock s'
      'left join marcas m on m.marca_stk=s.marca_stk'
      
        'where ( s.subrubro_stk = :sub or :sub = '#39'*****'#39' ) and ( s.clase_' +
        'articulo > 0 )'
      'order by s.detalle_stk')
    Left = 572
    Top = 528
    ParamData = <
      item
        Position = 1
        Name = 'sub'
        DataType = ftString
        ParamType = ptInput
        Value = Null
      end>
  end
