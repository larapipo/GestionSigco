  object QStock: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select s.codigo_stk,s.detalle_stk,g.tasa,s.modo_gravamen,'
      '       s.fijacion_precio_exento,s.fijacion_precio_gravado,'
      '       s.reemplazo_stk,'
      
        '       lp.recargo, lp.precio, coalesce(lp.descuento,0) as descue' +
        'nto,'
      
        '       lp2.recargo as recargo_2,lp2.precio as Precio2,Coalesce(l' +
        'p2.descuento,0) as descuento_2, '
      
        '       lp.precio_gravado as PrecioGravado, lp2.precio_gravado as' +
        ' PrecioGravado2,s.foto ,s.url from stock s'
      'left join gravamen g on g.codigo=s.tasa_iva'
      
        'left join listaprecioespecialart lp on lp.codigoarticulo=s.codig' +
        'o_stk'
      
        'left join listaprecioespecialart lp2 on lp2.codigoarticulo=s.cod' +
        'igo_stk'
      ''
      
        'where s.codigo_stk=:Codigo and lp.id_cab=:lista and lp2.id_cab=:' +
        'lista2')
    Left = 456
    Top = 376
    ParamData = <
      item
        Name = 'CODIGO'
        DataType = ftString
        ParamType = ptInput
        Size = 8
        Value = Null
      end
      item
        Name = 'LISTA'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'LISTA2'
        DataType = ftInteger
        ParamType = ptInput
      end>
    object QStockCODIGO_STK: TStringField
      FieldName = 'CODIGO_STK'
