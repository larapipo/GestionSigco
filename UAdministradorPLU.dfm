        '  case when ((s.detalle_corto='#39#39') or (s.detalle_corto is null)) ' +
        'Then s.detalle_stk'
      '  else s.detalle_corto'
      '  end as detalle_stk,'
      
        '  s.unidad,s.plu, case  when s.plu <= :Lte then (select l1.preci' +
        'o from listaprecioespecialart l1 where l1.codigoarticulo=s.codig' +
        'o_stk and l1.id_cab=:Lista_1)'
      '                                                          else'
      
        '                                                        (select ' +
        'l2.precio from listaprecioespecialart l2 where l2.codigoarticulo' +
        '=s.codigo_stk and l2.id_cab=:Lista_2)'
      
        '                                                   end as Precio' +
        '_1,'
      ''
      
        '                                                   case  when s.' +
        'plu <= :Lte then (select l1.precio from listaprecioespecialart l' +
        '1 where l1.codigoarticulo=s.codigo_stk and l1.id_cab=:Lista_1)'
      '                                                          else'
      
        '                                                        (select ' +
        'l2.precio from listaprecioespecialart l2 where l2.codigoarticulo' +
        '=s.codigo_stk and l2.id_cab=:Lista_2)'
      
        '                                                   end as Precio' +
        '_2'
      
        '                                                   ,coalesce(s.p' +
        'lu_seccion ,0)as Seccion,'#39#39' as detallesec,s.rubro_stk,r.detalle_' +
        'rubro from stock s'
      ''
      'left join  rubros r on r.codigo_rubro=s.rubro_stk'
      
        'where s.clase_articulo in (1,3) and s.plu<>'#39#39'  and s.plu<>'#39'00000' +
        #39
      'order by s.plu')
