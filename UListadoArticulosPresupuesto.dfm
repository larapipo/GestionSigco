  object QPresupuestos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select d.*,c.codigo as CodigoCliente,c.nombre,c.razonsocial,c.li' +
        'staprecio,'
      
        'c.netograv2,c.netoexen2,c.total as TotalPresu,c.dstoimporte from' +
        ' presdet d'
      'left join prescab c on c.id_pr=d.id_cabpres'
      'where c.fechavta between :desde and :hasta')
    Left = 216
    Top = 209
    ParamData = <
      item
        Name = 'DESDE'
        DataType = ftTimeStamp
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'HASTA'
        DataType = ftTimeStamp
        ParamType = ptInput
      end>
