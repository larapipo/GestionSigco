  object QAjustesSeries: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select a.*,'
      '  cp.denominacion as MuestraComprobante,'
      '  s.detalle as MuestraSucursal,'
      '  cp.id_comprobante as id_tipocomprobante,'
      '  d.nombre as MuestraDeposito from ajuste_nro_series a'
      'left join depositos d  on d.id=a.deposito'
      'left join sucursal s on s.codigo=a.sucursal'
      'left join comprobantes cp on cp.clase_comprob=a.ClaseCpbte and'
      '          cp.letra=a.Letra and'
      '          cp.sucursal=a.sucursal and'
      '          cp.tipo_comprob=a.tipocpbte and'
      '          cp.compra_venta='#39'V'#39
      'where a.id=:id'
      ' '
      ' ')
    Left = 40
    Top = 200
    ParamData = <
      item
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
