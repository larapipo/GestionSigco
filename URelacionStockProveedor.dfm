  object QStockProveedor: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select r.*, s.detalle_stk as MuestraStock from RELACION_ARTICULO' +
        'PROVEE R'
      'left join stock s on s.codigo_stk=r.codigo_stk'
      'where r.codigo_prov=:codigo'
      'order by r.orden')
