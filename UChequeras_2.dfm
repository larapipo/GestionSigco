  object QLstCheques: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select ch.fecha_cobro,ch.fecha_debito,ch.fecha_emision,'
      '       ch.anulado,ch.debitado,ch.numero,ch.importe,ch.orden_de,'
      
        '       c.tipo_comprob,c.clase_comprob,c.id_comprobante,c.nro_com' +
        'probante from cheque_propio ch'
      ''
      'left join caja_mov c on c.id_mov_caja=ch.id_mov_caja'
      ''
      'where ch.id_chequera=:id'
      'order by ch.numero asc')
