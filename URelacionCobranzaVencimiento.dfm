  object QMovAplicaCCVta: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select M.*,'
      '  f.fechavta as MuestraFechaCpbte,'
      '  f.total as MuestraTotalFC,'
      
        '  f.tipo_vta as MuestraTipoVta, m.importe as Saldo,f.tipo_vta fr' +
        'om MovAplicaCCVta M'
      
        'left join fcvtacab f on f.id_fc=m.aplica_id_cpbte and f.tipocpbt' +
        'e=m.aplica_tipocpbte'
      'Where M.id_cpbte=:id and M.tipoCpbte=:Tipo')
    Left = 632
    Top = 152
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'Tipo'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object QRecibos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select r.*,p.nombre as MuestraVendedor,pc.porcentaje from recibo' +
        's r'
      'left join personal p on p.codigo=r.vendedor'
      ''
      'left join comprobantes c on c.tipo_comprob=r.tipocpbte and'
      '                            c.clase_comprob=r.clasecpbte and'
      '                            c.letra=r.letrarc and'
      '                            c.sucursal = r.sucursal and'
      '                            c.compra_venta='#39'V'#39
      
        'left join personal_cpbte pc on pc.id_cpbte=c.id_comprobante and ' +
        'pc.codigo=r.vendedor'
      ''
      'where ( r.fecha between :desde and :hasta ) and'
      '      ( r.vendedor = :vendedor or :vendedor = '#39'******'#39' )'
      'order by r.vendedor,r.fecha')
    Left = 120
    Top = 416
    ParamData = <
      item
        Position = 1
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'vendedor'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 4
        Name = 'vendedor'
        DataType = ftString
        ParamType = ptInput
      end>
  end
  object QVendedor: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select codigo,nombre from personal '
      ' where vendedor='#39'S'#39
      'order by nombre')
    Left = 352
    Top = 424
  end
  object QMovCaja: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select m.* from MOV_VALORES_RECIBO (:id) m'
      'order by m.id_modopago,m.fecha_cobro'
      '')
    Left = 608
    Top = 472
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
