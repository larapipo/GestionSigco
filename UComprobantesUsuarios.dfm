  object QCompUsuario: TFDQuery
    CachedUpdates = True
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select cu.*, c.denominacion as MuestraComprobante,'
      
        '         c.tipo_comprob as MuestraTipo,c.clase_comprob as Muestr' +
        'aClase,s.detalle as MuestraSucursal,s.codigo as MuestraSUc from ' +
        'comprobantes_usuarios cu '
      'left join comprobantes c on c.id_comprobante=cu.id_comprobante'
      'left join sucursal s on s.codigo=c.sucursal'
      'where cu.id_usuario=:id'
      'order by s.codigo')
