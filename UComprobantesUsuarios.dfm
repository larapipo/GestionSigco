  object QComprobantes: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select c.id_comprobante,c.tipo_comprob,clase_comprob,c.Denominac' +
        'ion,'
      
        '       c.sucursal,s.detalle as MuestraSucursal from comprobantes' +
