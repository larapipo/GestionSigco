    <Target Name="ExporadorLista:Make">
        <MSBuild Projects="..\ExportadorLista\ExporadorLista.dproj" Targets="Make"/>
    </Target>
    <Target Name="Build">
        <CallTarget Targets="Menu;ExporadorLista"/>
    </Target>
    <Target Name="Clean">
        <CallTarget Targets="Menu:Clean;ExporadorLista:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="Menu:Make;ExporadorLista:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
</Project>
