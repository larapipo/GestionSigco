  object QCtasCaja: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.* from cuenta_caja c'
      'left join caja_cab cc on cc.id_cuenta_caja=c.id_cuenta'
      'where c.id_tipo_cta=1'
      'and cc.estado=0')
    Left = 336
    Top = 368
  end
