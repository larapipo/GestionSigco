    SQL.Strings = (
      
        'select ind.*,s.detalle_stk as MuestraDetalle,s.rubro_stk as Mues' +
        'traRubro,'
      
        '  s.subrubro_stk as MuestraSubRubro,s.marca_stk as MuestraMarca,' +
        's.reemplazo_stk as MuestraCodAlternativo,'
      
