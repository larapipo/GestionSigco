  object QStockFisico: TFDQuery
    Connection = DMMain_FD.fdcGestion
    FormatOptions.AssignedValues = [fvMapRules]
    FormatOptions.OwnMapRules = True
    FormatOptions.MapRules = <
      item
        SourceDataType = dtDateTimeStamp
        TargetDataType = dtDate
      end
      item
        SourceDataType = dtDateTime
        TargetDataType = dtDate
      end>
    SQL.Strings = (
      'select d.codigo_deposito as CodigoDeposito,'
      '       d.codigo_stk as CodigoArticulo,'
      '       Sum(d.fisico) as Cantidaddecimal,'
      
        '       coalesce(d.fuaprecios,current_timestamp) as VencimientoLo' +
        'te,   '
      
        '       coalesce(d.fuaprecios,current_timestamp) as FechaStock  f' +
        'rom depositostk d'
      'group by d.codigo_deposito,d.codigo_stk,d.fuaprecios')
    Left = 32
    Top = 96
