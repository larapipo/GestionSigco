  object QClientesRutas: TFDQuery
    Connection = DMMain_FD.fdcGestion
    FormatOptions.AssignedValues = [fvMapRules]
    FormatOptions.OwnMapRules = True
    FormatOptions.MapRules = <
      item
        SourceDataType = dtDateTimeStamp
        TargetDataType = dtDate
      end
      item
        SourceDataType = dtDateTime
        TargetDataType = dtDate
      end>
    SQL.Strings = (
      'select (case when coalesce( c.sucursal,0)<=0 Then 1'
      '             when coalesce( c.sucursal,0)>0 Then c.sucursal'
      '        end) as CodigoSucursal,'
      '       1 as CodigoFuerza,'
      '       '#39'PRE'#39' as CodigoModoAtencion,'
      '       (case when coalesce( c.zona,0)=0 Then 1'
      '             when coalesce( c.zona,0)>0 Then c.zona'
      ''
      '        '
      '        end) as CodigoRuta,'
      '       c.codigo as CodigoCliente,'
      '       '#39'01/01/2000'#39' as FechaDesde,'
      '       '#39'31/12/9999'#39' as FechaHasta  from clientes c')
    Left = 120
    Top = 96
