  object QPersonalComercial: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select coalesce(p.sucursal,1) as CodigoSucursal,'
      '      p.codigo as CodigoPersonal,'
      '      p.nombre as Descripcion,'
      '      '#39'V'#39' as Cargo,'
      '      (case'
