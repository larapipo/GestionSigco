  object QClientes: TFDQuery
    Connection = DMMain_FD.fdcGestion
    FormatOptions.AssignedValues = [fvMapRules, fvStrsTrim]
    FormatOptions.OwnMapRules = True
    FormatOptions.MapRules = <
      item
        SourceDataType = dtDateTime
        TargetDataType = dtDate
      end
      item
        SourceDataType = dtDateTimeStamp
        TargetDataType = dtDate
      end>
    SQL.Strings = (
      'select 1 as codigoSucursal,'
      '       c.codigo as CodigoCliente,'
      '       c.nombre,'
      '       c.direccion_comercial as domicilio,'
      '       c.categoria as IdCanalAgrupa,'
      '       ct.detalle as DescCanalAgrupa,'
      '       1 as IdSubCanal,'
      '       '#39#39' as DescSubCanalAgrupa,'
      '       c.fechaalta,'
      '       (case when c.activo='#39'S'#39' Then '#39'NO'#39
      '             when c.activo='#39'N'#39' Then '#39'SI'#39
      '             else '#39'NO'#39
      '        end) as Anulado,'
      ''
      '       (case when c.condicion_iva=1 Then '#39'RI'#39
      '             when c.condicion_iva=2 Then '#39'MT'#39
      '             when c.condicion_iva=3 Then '#39'CF'#39
      '             when c.condicion_iva=4 Then '#39'NI'#39
      '             when c.condicion_iva=5 Then '#39'MT'#39
      '             when c.condicion_iva=6 Then '#39'EX'#39
      '       end) as TipoContribuyente,'
      '       (case when c.condicion_iva=1 Then 80'
      '             when c.condicion_iva=2 Then 80'
      '             when c.condicion_iva=3 Then 96'
      '             when c.condicion_iva=4 Then 80'
      '             when c.condicion_iva=5 Then 80'
      '             when c.condicion_iva=6 Then 80'
      '       end) as idTipoDocumento,'
      ''
      '       '#39#39' as CodListaPrecio,'
      '       c.cpostal as codigoLocalidad,'
      '       c.localidad as DescripcionLocalidad,'
      '       p.nombre as DescProvincia'
      ''
      '        from clientes c'
      'left join clientes_categorias ct on ct.id=c.categoria'
      'left join c_postal cp on cp.id_postal=c.id_cod_postal'
      'left join provincia p on p.id_pro=cp.provincia')
    Left = 636
    Top = 113
