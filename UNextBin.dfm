  object QComprobantes: TFDQuery
    OnCalcFields = QComprobantesCalcFields
    Connection = DMMain_FD.fdcGestion
    FormatOptions.AssignedValues = [fvMapRules]
    FormatOptions.OwnMapRules = True
    FormatOptions.MapRules = <
      item
        SourceDataType = dtDateTime
        TargetDataType = dtDate
      end
      item
        SourceDataType = dtDateTimeStamp
        TargetDataType = dtDate
      end>
    SQL.Strings = (
      'select d.tipocpbte as TipoCOmprobante,'
      
        '       c.letrafac LetraComprobante, c.sucfac as SerieComprobante' +
        ','
      '       c.numerofac as NumeroComprobante,'
      '       d.renglon as NumeroLinea,'
      '       1 as CodigoFuerza,'
      '       '#39'YES'#39' as EsVenta,'
      '       d.codigoarticulo,'
      '       s.detalle_stk as DescripcionArticulo,'
      '       1 as UnidadesPorBulto,'
      '       (case when d.tipocpbte='#39'NC'#39' Then d.cantidad * -1'
      '        else d.cantidad end) as CantidadDecimal,'
      '       '
      '       d.unitario_total as PrecioUnitarioBruto,'
      '       d.descuento as bonificacion,'
      
        '       c.fechavta as FechaPedido, c.fechavta as FechaComprobante' +
        ',  c.codigo as codigocliente,'
      '       c.sucursal as codigosucursal,'
      '       c.nombre as NombreCliente,'
      '      (case when c.tipoiva=1 Then '#39'RI'#39
      '            when c.tipoiva=2 Then '#39'RNI'#39
      '            when c.tipoiva=3 Then '#39'CF'#39
      '            when c.tipoiva=4 Then '#39'NI'#39
      '            when c.tipoiva=5 Then '#39'MT'#39
      '            when c.tipoiva=6 Then '#39'EX'#39
      '       end) as TipoContribuyente,'
      '       (case when c.anulado='#39'N'#39' Then '#39'NO'#39
      '             when c.anulado='#39'S'#39' Then '#39'SI'#39
      '         end) as Anulado'
      '                from fcvtadet d'
      '  left join fcvtacab c on c.id_fc=d.id_cabfac'
      '  left join stock s on s.codigo_stk=d.codigoarticulo'
      'where d.fechavta between :Desde and :Hasta')
    Left = 452
    Top = 105
    ParamData = <
      item
        Name = 'DESDE'
        DataType = ftTimeStamp
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'HASTA'
        DataType = ftTimeStamp
        ParamType = ptInput
      end>
