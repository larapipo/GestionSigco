  object QRet: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select r.id, r.id_liq as ID_origen,r.fecha,r.numero_retencion,r.' +
        'observaciones,'
      '       r.codigo_proveedor,r.codigo_regimen,r.concepto,r.tasa,'
      
        '       r.base_imponible,r.minimo_no_imponible,r.impuesto_retenid' +
        'o,'
      
        '       r.anulada,r.estado,p.razon_social,p.n_de_cuit,p.condicion' +
        '_iva, f.tipocomp_afip as Tipo_CPBTE,'
      
        '       f.tipo_liquidacion as tipo_liquidacion,p.direccion,p.loca' +
        'lidad,p.cod_postal'
      'from retenciones_iva_liq r'
      '  left join poveedor p on p.codigo=r.codigo_proveedor'
      '  left join fccompcab f on f.id_fc=r.id_liq'
      'where r.fecha between :desde and :hasta'
      'union'
      
        'select r2.id, r2.id_op as ID_origen,r2.fecha,r2.numero_retencion' +
        ',r2.observaciones,'
      
        '       r2.codigo_proveedor,r2.codigo_regimen,r2.concepto,r2.tasa' +
        ','
      
        '       r2.base_imponible,r2.minimo_no_imponible,r2.impuesto_rete' +
        'nido,'
      
        '       r2.anulada,r2.estado,p2.razon_social,p2.n_de_cuit,p2.cond' +
        'icion_iva,cast( '#39'006'#39' as Varchar(3)) as Tipo_CPBTE,'
      
        '       Cast( '#39'X'#39' as char(1)) as tipo_liquidacion,p2.direccion,p2' +
        '.localidad,p2.cod_postal'
      ''
      'from retenciones_iva r2'
      '  left join poveedor p2 on p2.codigo  =r2.codigo_proveedor'
      '  left join ordenpago op on op.id_op  =r2.id_op'
      'where r2.fecha between :desde and :hasta')
    Left = 72
    Top = 136
    ParamData = <
      item
        Position = 1
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end>
  end
