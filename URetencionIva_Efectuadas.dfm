  object Memo1: TMemo [3]
    Left = 254
    Top = 488
    Width = 422
    Height = 110
    Lines.Strings = (
      'select retenciones_iva.id,'
      '    retenciones_iva.id_op as ID_origen,'
      '    retenciones_iva.fecha,'
      '    retenciones_iva.numero_retencion,'
      '    retenciones_iva.codigo_proveedor,'
      '    retenciones_iva.codigo_regimen,'
      '    retenciones_iva.concepto,'
      '    retenciones_iva.tasa,'
      '    retenciones_iva.base_imponible,'
      '    retenciones_iva.minimo_no_imponible,'
      '    retenciones_iva.impuesto_retenido,'
      '    retenciones_iva.observaciones,'
      '    retenciones_iva.anulada,'
      '    retenciones_iva.estado,'
      
        '    p.razon_social,p.n_de_cuit,p.condicion_iva,'#39'06'#39' as Tipo_CPBT' +
        'E'
      'from retenciones_iva'
      
        'left join poveedor p on p.codigo=retenciones_iva.codigo_proveedo' +
        'r'
      'where retenciones_iva.fecha between :desde and :hasta'
      'union'
      'select'
      '    retenciones_iva_liq.id,'
      '    retenciones_iva_liq.id_liq as ID_origen,'
      '    retenciones_iva_liq.fecha,'
      '    retenciones_iva_liq.numero_retencion,'
      '    retenciones_iva_liq.codigo_proveedor,'
      '    retenciones_iva_liq.codigo_regimen,'
      '    retenciones_iva_liq.concepto,'
      '    retenciones_iva_liq.tasa,'
      '    retenciones_iva_liq.base_imponible,'
      '    retenciones_iva_liq.minimo_no_imponible,'
      '    retenciones_iva_liq.impuesto_retenido,'
      '    retenciones_iva_liq.observaciones,'
      '    retenciones_iva_liq.anulada,'
      '    retenciones_iva_liq.estado,'
      
        '    p.razon_social,p.n_de_cuit,p.condicion_iva,'#39'05'#39' as Tipo_CPBT' +
        'E'
      'from retenciones_iva_liq'
      
        'left join poveedor p on p.codigo=retenciones_iva_liq.codigo_prov' +
        'eedor'
      'where retenciones_iva_liq.fecha between :desde and :hasta')
    ScrollBars = ssVertical
    TabOrder = 3
    Visible = False
  end
