  object QMovCC: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select * from MOV_CTACTE_VTA (:codigo,:desde,:hasta )'
      'order by  '
      'fechavta,tipocpbte,nrocpbte ')
    Left = 445
    Top = 375
    ParamData = <
      item
        Position = 1
        Name = 'codigo'
        DataType = ftString
        ParamType = ptInput
