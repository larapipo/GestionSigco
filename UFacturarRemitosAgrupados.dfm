  object QClientes: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select distinct c.codigo,c.nombre from rtocab c'
      'where ( (c.idfactura is null) or (c.idfactura<=0) )'
      
        'and c.sucursal=:Sucursal and c.deposito=:deposito and c.anulado=' +
        #39'N'#39
