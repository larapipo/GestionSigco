  object QFacturasCliente: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select f.id_fc,f.tipocpbte,f.clasecpbte,f.letrafac,f.sucfac,f.nu' +
        'merofac,f.nrocpbte,'
      
        '       f.codigo,f.nombre,f.razonsocial,r.id_rto,r.tipocpbte as T' +
        'iporto,r.clasecpbte as claserto,'
      
        '       r.nrocpbte as nrorto,r.fechavta as fecharto from fcvtacab' +
        ' f'
      'left join rtocab r on r.idfactura=f.id_fc'
      
        'where f.codigo = :codigo and f.fechavta between :desde and :hast' +
        'a')
