  object QRtoCab: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select c.id_rto,c.codigo,c.nombre,ldr.nombre as MuestraLDR,ldr.d' +
        'ireccion as MuestraLDRDir, c.fechavta,c.sucursal,c.ldr,'
      'c.condicionvta,c.tipocpbte,c.nrocpbte,c.deposito,c.numerorto,'
      'c.zona,c.nrofact,c.idfactura,c.listaprecio,c.renglones,'
      'c.observacion1,c.observacion2,c.total,c.tipoiva from rtocab c'
      
        'left join ldrcliente ldr on ldr.codigo_ldr=c.ldr and ldr.codigo_' +
        'cliente=c.codigo'
      'where ( (c.idfactura is null) or (c.idfactura<=0) )'
      
        'and c.sucursal=:Sucursal and c.deposito=:deposito and c.anulado=' +
        #39'N'#39' and c.devolucion <>'#39'S'#39
      'order by c.ldr,c.nombre')
    Left = 40
    Top = 184
    ParamData = <
      item
        Name = 'Sucursal'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Name = 'deposito'
        DataType = ftInteger
        ParamType = ptInput
      end>
    object QRtoCabID_RTO: TIntegerField
