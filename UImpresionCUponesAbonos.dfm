  object QGrupos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select cg.cliente,c.nombre as MuestraNombre,cg.id_cupon_grupo,'
      '       cgr.detalle as MuestraGrupo,cgr.precio1,'
      '       cgr.precio2,cgr.vto_1,cgr.vto_2,'
      '       cgr.codigoarticulo,'
      
        '       c.id_facturapordefecto,c.sucursal,c.correoelectronico,cpb' +
        'te.letra as MuestraLetra from cupon_abonos_grilla cg'
      'left join clientes c on c.codigo=cg.cliente'
      'left join cupon_abonos_grupos cgr on cgr.id=cg.id_cupon_grupo'
      
        'left join comprobantes cpbte on cpbte.id_comprobante=c.id_factur' +
        'apordefecto'
      'where cg.id_cupon_grupo = :grupo and c.activo='#39'S'#39)
    Left = 112
    Top = 360
    ParamData = <
      item
        Name = 'grupo'
        DataType = ftInteger
        ParamType = ptInput
      end>
