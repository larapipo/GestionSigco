  object QCondiciones: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select * from clientes_cond_abono c where c.codigo = :codigo and' +
        ' '
      '( :fecha >= c.desde and  :fecha <= c.hasta ) and c.estado='#39'S'#39)
    Left = 144
    Top = 512
    ParamData = <
      item
        Name = 'codigo'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'fecha'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'fecha'
        DataType = ftDate
        ParamType = ptInput
      end>
  end
