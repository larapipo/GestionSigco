  object QRtosCab: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select r.*,'
      '       c.id_facturapordefecto,'
      '       i.detalle as MuestraIva'
      'from rtocab r'
      '  left join clientes c on c.codigo=r.codigo'
      '  left join inscripcion i on i.codigo=r.tipoiva'
      
        'where ((r.idfactura is null) or (r.idfactura<=0) ) and r.devoluc' +
        'ion<>'#39'S'#39
      
        '       and r.sucursal=:Sucursal and r.deposito=:deposito and r.a' +
        'nulado='#39'N'#39
      'order by r.nrocpbte desc')
    Left = 48
    Top = 280
    ParamData = <
      item
        Position = 1
        Name = 'Sucursal'
        DataType = ftInteger
        ParamType = ptInput
        Value = Null
      end
      item
        Position = 2
        Name = 'deposito'
        DataType = ftInteger
        ParamType = ptInput
      end>
