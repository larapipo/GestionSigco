  object QStockSeries: TSQLQuery
    MaxBlobSize = -1
    Params = <
      item
        DataType = ftString
        Name = 'Codigo_Stk'
        ParamType = ptInput
      end
      item
        DataType = ftInteger
        Name = 'disponible'
        ParamType = ptInput
      end
      item
        DataType = ftInteger
        Name = 'disponible'
        ParamType = ptInput
      end>
    SQL.Strings = (
      'select *  from Stock_series Where codigo_stk=:Codigo_Stk'
      
        'and ((((id_cpbte_egreso is null) or (id_cpbte_egreso=0)) and (:d' +
        'isponible = 0))'
      '    or ( :disponible = -1 ))'
      'order by codigoserie desc')
