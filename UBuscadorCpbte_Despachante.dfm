  object QBuscaCpbte: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select f.FechaVta ,f.tipocpbte as TP,f.clasecpbte as CL, f.letra' +
        'fac,f.sucfac,f.numerofac,f.Codigo, f.Nombre,'
      
        '       f.Total,f.tipo_operacion_expo, f.doc_aduanero,f.nro_inter' +
        'no,f.referencia_expo ,'
      
        '       aori.aduana as AduanaOrigne,ades.pais as AduanaDestino,f.' +
        'nrocpbte,f.id_fc , f.anulado from FcVtaCab f'
      'left join paises ades on ades.id=f.id_destino'
      'left join aduanas aori on aori.id=f.id_aduana'
      
        'order by f.fechavta desc, f.tipocpbte asc,f.clasecpbte, f.nrocpb' +
        'te desc')
    Left = 344
    Top = 96
  end
  object QTipoCom: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.*, s.detalle as MuestraSucursal from comprobantes c'
      'left join sucursal s on s.codigo=c.sucursal'
      'where c.compra_venta=:compra_venta and'
      '      c.tipo_comprob in (:tipo1,:tipo2,:tipo3) and'
      '      c.sucursal = :suc'
      'order by c.sucursal,c.tipo_comprob ')
    Left = 32
    Top = 296
    ParamData = <
      item
        Position = 1
        Name = 'compra_venta'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'tipo1'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'tipo2'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 4
        Name = 'tipo3'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Position = 5
        Name = 'suc'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
  object QBuscarClaseCpbte: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select c.denominacion as nombre ,c.letra, min (c.clase_comprob) ' +
        'as clase from comprobantes c'
      'where c.compra_venta=:compra_venta and'
      '      c.tipo_comprob=:tipo and'
      '      c.sucursal=:sucursal'
      'group by c.denominacion,c.letra')
    Left = 432
    Top = 288
    ParamData = <
      item
        Name = 'COMPRA_VENTA'
        DataType = ftString
        ParamType = ptInput
        Size = 1
        Value = Null
      end
