  object QPlantillas: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.codigo,c.nombre as MuestraNombre,'
      
        '  c.id_plantilla,pla_cab.detalle as MuestraPlantilla,c.con_gprs,' +
        'c.con_monitoreo,c.con_hosting,'
      '  c.cobrador,e.nombre as MuestraCobrador'
      'from clientes c'
      '  left join plantillas_cab pla_cab on pla_cab.id=c.id_plantilla'
      '  left join personal e on e.codigo=c.cobrador'
      
        'where ( c.id_plantilla = :estado ) or ( :estado = -1 ) and c.act' +
        'ivo<>'#39'N'#39
      'order by c.codigo')
    Left = 136
    Top = 152
    ParamData = <
      item
        Position = 1
        Name = 'estado'
        DataType = ftInteger
        ParamType = ptInput
        Value = Null
      end>
