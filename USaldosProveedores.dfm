  object QSaldosProvee: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select mc.proveedor,P.NOMBRE,p.razon_social,p.n_de_cuit,(sum(mc.' +
        'haber)-sum(mc.debe)) as total from MOVCCCOMPRA_TEMPORAL  mc'
      'JOIN POVEEDOR P ON P.CODIGO=MC.PROVEEDOR '
      
        'where mc.fechacompra<=:hasta and p.activo='#39'S'#39' and ( mc.sucursal ' +
        '= :suc or :suc = -1 ) '
      'group by mc.proveedor,P.NOMBRE,p.razon_social,p.n_de_cuit'
      ''
      
        'having (sum(mc.Haber-mc.debe)>=:minimo) and (sum(mc.haber-mc.deb' +
        'e)<=:maximo)')
    Left = 56
    Top = 79
    ParamData = <
      item
        Position = 1
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'suc'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 3
        Name = 'suc'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 4
        Name = 'minimo'
        DataType = ftFloat
        ParamType = ptInput
      end
      item
        Position = 5
        Name = 'maximo'
        DataType = ftFloat
        ParamType = ptInput
      end>
  end
