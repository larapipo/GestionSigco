  object QMovACta: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select m.* from MovACtaCCcompra_temporal m where '
      
        '  m.id = :id and  m.Importe<>0 and ( sucursal = :suc or :suc = -' +
        '1 )'
      'order by m.proveedor, m.fecha,m.numerocpbte')
    Left = 600
    Top = 215
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'suc'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
  object QMovCC: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select mc.id_movcccompra, mc.proveedor,mc.fechacompra,mc.fechavt' +
        'o,mc.detalle,mc.debe,mc.haber,'
      
        'mc.saldo,mc.tipocpbte,mc.clasecpbte,mc.id_comprobante,mc.id_cpbt' +
        'e from movcccompra_temporal  mc'
      
        'where mc.saldo>0 and mc.id = :id and ( mc.sucursal = :suc or :su' +
        'c = -1 )'
      'order by mc.proveedor,mc.fechacompra desc')
    Left = 600
    Top = 79
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end
      item
        Position = 2
        Name = 'suc'
        DataType = ftInteger
        ParamType = ptInput
      end>
  end
  object QFiltroDet: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select tc.*,'
      'c.denominacion as MuestraComprobante,'
      'c.tipo_comprob as MuestraTipo,'
      'c.clase_comprob as MuestraClase,'
      's.detalle  as MuestraSuc from tabla_cpbte_ccCOMP_det tc'
      'left join comprobantes c on c.id_comprobante=tc.id_cpbte'
      'left join sucursal s on s.codigo=c.sucursal'
      'where tc.id_cab=:id'
      'order by s.detalle,c.tipo_comprob,c.clase_comprob')
    Left = 616
    Top = 391
    ParamData = <
      item
        Position = 1
        Name = 'id'
        DataType = ftInteger
        ParamType = ptInput
      end>
