  object QBuscaCuponCliente: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select c.id,c.numero,c.factura_id,c.factura_fecha,'
      '       c.factura_clase,c.codigobarra1,c.factura_tipo,'
      
        '       c.factura_nrocpbte,c.pagado,c.periodo,c.importe_1,c.impor' +
        'te_2 from cupon_abonos c'
      'where c.cliente=:cliente and c.pagado='#39'N'#39
      'order by c.factura_fecha desc')
    Left = 576
    Top = 128
    ParamData = <
      item
        Name = 'cliente'
        DataType = ftString
        ParamType = ptInput
