  object QRecibos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select r.id_rc,r.tipocpbte,r.clasecpbte,r.razonsocial, r.nrocpbt' +
        'e,r.fecha,r.total  from recibos r'
      ''
      
        'where ((r.vendedor = :cobrador) or (:cobrador = '#39'******'#39'))  and ' +
        '( r.fecha between :desde and :hasta )')
