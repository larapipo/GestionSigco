  object QSaldo: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select (Sum(m.debe)-Sum(m.haber)) as SAldo from movccvta m'
      'left join clientes c on c.codigo = m.cliente'
      'where c.vendedor = :vendedor and m.fechavta<= :hasta')
    Left = 1065
    Top = 270
