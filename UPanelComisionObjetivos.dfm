  object QCobros: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'select r.id_rc,r.tipocpbte,r.clasecpbte,r.nrocpbte,r.fecha,r.tot' +
        'al,'
      
        '       m.aplica_tipocpbte,m.aplica_clasecpbte,m.aplica_nrocpbte,' +
        'f.fechavta, m.importe ,'
      '       (r.fecha - f.fechavta) as Mora from recibos r'
      
        'left join movaplicaccvta m on m.id_cpbte=r.id_rc and m.tipocpbte' +
        '=r.tipocpbte'
      'left join fcvtacab f on f.id_fc=m.aplica_id_cpbte'
      
        'where ((r.vendedor = :cobrador) or (:cobrador = '#39'******'#39'))  and ' +
        '( r.fecha between :desde and :hasta )')
    Left = 712
    Top = 256
    ParamData = <
      item
        Name = 'cobrador'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'cobrador'
        DataType = ftString
        ParamType = ptInput
      end
      item
        Name = 'desde'
        DataType = ftDate
        ParamType = ptInput
      end
      item
        Name = 'hasta'
        DataType = ftDate
        ParamType = ptInput
      end>
  end
