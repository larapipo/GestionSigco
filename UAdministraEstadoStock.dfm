  object QPercivaIVA: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      
        'update stock s set s.percibe_iva= :Estado, s.id_tasa_percep_iva ' +
        '= :idtasa'
      
        'where  ( (s.rubro_stk=:rubro or :rubro = '#39'***'#39' ) and (s.subrubro' +
