  object QStockConceptos: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'update stock s set s.controlastock= :Estado'
      'where ( Not(s.clase_articulo in (1,2,3)))'
      
        'and ( (s.rubro_stk=:rubro or :rubro = '#39'***'#39' ) and (s.subrubro_st' +
