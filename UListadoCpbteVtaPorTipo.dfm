  object QTipoCpbte: TFDQuery
    Connection = DMMain_FD.fdcGestion
    SQL.Strings = (
      'select * from tipo_comprobante'
      
        'where tipo_de_operacion<>'#39'C'#39' and (sigla in ('#39'FC'#39','#39'NC'#39','#39'ND'#39','#39'FO'#39',' +
        #39'TK'#39'))')
