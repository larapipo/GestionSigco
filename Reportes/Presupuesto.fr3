<TfrxReport Version="2024.1.8" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.MDIChild="True" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Brother HL-2130 series" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="39638.1218721644" ReportOptions.Description.Text="" ReportOptions.LastChange="45640.3393855324" ScriptLanguage="PascalScript" ScriptText.Text="var Unitario,Total:Real;&#13;&#10;&#13;&#10;&#13;&#10;procedure DetalleOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;    if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      DetalleIva.visible   :=False;&#13;&#10;      Memo21.Visible:=False;&#13;&#10;      Memo27.Visible:=False;&#13;&#10;      Memo29.Visible:=False;&#13;&#10;      Memo25.Visible:=True;&#13;&#10;      Memo30.Visible:=False;&#13;&#10;&#13;&#10;      Memo26.Visible:=False;&#13;&#10;      Memo24.Visible:=True;&#13;&#10;      Memo16.Visible:=False;&#13;&#10;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      DetalleIva.visible:=True;&#13;&#10;      Memo21.Visible:=True;&#13;&#10;      Memo27.Visible:=True;&#13;&#10;&#13;&#10;      Memo29.Visible:=True;&#13;&#10;      Memo25.Visible:=True;&#13;&#10;      Memo30.Visible:=True;&#13;&#10;&#13;&#10;      Memo26.Visible:=True;&#13;&#10;      Memo24.Visible:=True;&#13;&#10;      Memo16.Visible:=True;&#13;&#10;&#13;&#10;    end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; if &#60;frDBDetalle.&#34;ACEPTADO&#34;&#62;='S' Then&#13;&#10;   MasterData4.Visible:=True&#13;&#10; else&#13;&#10;   MasterData4.Visible:=False;&#13;&#10;&#13;&#10; if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_GRAVADO&#34;&#62;*(1+&#60;frDBDetalle.&#34;IVA_TASA&#34;&#62;*0.01)+&#60;frDBDetalle.&#34;UNITARIO_EXENTO&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;      Total   :=Unitario*&#60;frDBDetalle.&#34;CANTIDAD&#34;&#62;;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_Total&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;        Total   :=&#60;frDBDetalle.&#34;Total&#34;&#62;;&#13;&#10;    end;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
