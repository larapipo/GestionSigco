<TfrxReport Version="2022.2.3" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Por defecto" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="39638.1218496759" ReportOptions.Description.Text="" ReportOptions.LastChange="45070.6382815278" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;  FechaCobro,Banco,CheNro:String;&#13;&#10;  Importe,TotalValores:Real;&#13;&#10;&#13;&#10;procedure Band1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if &#60;frDBDMovCaja.&#34;ID_TPAGO&#34;&#62;=1 Then&#13;&#10;    begin&#13;&#10;      importe      :=&#60;frDBEfectivo.&#34;IMPORTE&#34;&#62;;&#13;&#10;      CheNro       :='';&#13;&#10;      FechaCobro   :='';&#13;&#10;      Banco        :='';&#13;&#10;      TotalValores := TotalValores+importe;&#13;&#10;   end&#13;&#10;  else&#13;&#10;    if &#60;frDBDMovCaja.&#34;ID_TPAGO&#34;&#62;=2 then&#13;&#10;      begin&#13;&#10;        banco       :='';&#13;&#10;        CheNro      := &#60;frDBCheque.&#34;NUMERO&#34;&#62;;&#13;&#10;        Importe     :=&#60;frDBCheque.&#34;IMPORTE&#34;&#62;;&#13;&#10;        FechaCobro  := &#60;frDBCheque.&#34;FECHA_COBRO&#34;&#62;;&#13;&#10;        banco       :=&#60;frDBCheque.&#34;MUESTRACHEQUERA&#34;&#62;;&#13;&#10;        TotalValores:= TotalValores+importe;&#13;&#10;      end&#13;&#10;    else&#13;&#10;      if &#60;frDBDMovCaja.&#34;ID_TPAGO&#34;&#62;=3 then&#13;&#10;        begin&#13;&#10;          banco        :='';&#13;&#10;          CheNro       :=&#60;frDBChe3.&#34;NUMERO&#34;&#62;;&#13;&#10;          Importe      :=&#60;frDBChe3.&#34;IMPORTE&#34;&#62;;&#13;&#10;          FechaCobro   :=&#60;frDBChe3.&#34;FECHA_COBRO&#34;&#62;;&#13;&#10;          Banco        :=&#60;frDBChe3.&#34;MUESTRABANCO&#34;&#62;;&#13;&#10;          TotalValores := TotalValores+importe;&#13;&#10;        end&#13;&#10;      else&#13;&#10;        if&#60;frDBDMovCaja.&#34;ID_TPAGO&#34;&#62;=6 then&#13;&#10;          begin&#13;&#10;            banco        :='';&#13;&#10;            CheNro       :=&#60;frDBDebitos.&#34;NUMERO&#34;&#62;;&#13;&#10;            Importe      :=&#60;frDBDebitos.&#34;IMPORTE&#34;&#62;;&#13;&#10;            FechaCobro   :=&#60;frDBDebitos.&#34;FECHA&#34;&#62;;&#13;&#10;            Banco        :=&#60;frDBDebitos.&#34;MUESTRACTACAJA&#34;&#62;;&#13;&#10;            TotalValores := TotalValores+importe;&#13;&#10;          end&#13;&#10;        else&#13;&#10;          if&#60;frDBDMovCaja.&#34;ID_TPAGO&#34;&#62;=5 then&#13;&#10;            begin&#13;&#10;              banco       :='';&#13;&#10;              CheNro      :=&#60;frDBTransf.&#34;NUMERO&#34;&#62;;&#13;&#10;              Importe     :=&#60;frDBTransf.&#34;IMPORTE&#34;&#62;;&#13;&#10;              FechaCobro  :=&#60;frDBTransf.&#34;FECHA&#34;&#62;;&#13;&#10;              Banco       :=&#60;frDBTransf.&#34;MUESTRACTACAJA&#34;&#62;;&#13;&#10;              TotalValores:= TotalValores+importe;&#13;&#10;            end&#13;&#10;          else&#13;&#10;            if&#60;frDBDMovCaja.&#34;ID_TPAGO&#34;&#62;=4 then&#13;&#10;              begin&#13;&#10;                banco       :='';&#13;&#10;                CheNro      :=&#60;frDBTC.&#34;NUMERO_CUPON&#34;&#62;;&#13;&#10;                Importe     :=&#60;frDBTC.&#34;IMPORTE&#34;&#62;;&#13;&#10;                FechaCobro  :=&#60;frDBTC.&#34;FECHA_CUPON&#34;&#62;;&#13;&#10;                Banco       :=&#60;frDBTC.&#34;MUESTRATC&#34;&#62;;&#13;&#10;                TotalValores:= TotalValores+importe;&#13;&#10;            end;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;end.">
