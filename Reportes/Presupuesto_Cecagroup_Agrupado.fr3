<TfrxReport Version="2024.1.8" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.MDIChild="True" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Default" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="39638.1218721644" ReportOptions.Description.Text="" ReportOptions.LastChange="45930.6505432407" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;Unitario,Total:Real;&#13;&#10;SUnitario,STotal:Real;&#13;&#10;totalItem:Real;&#13;&#10;&#13;&#10;&#13;&#10;procedure OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10; if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_GRAVADO&#34;&#62;*(1+&#60;frDBDetalle.&#34;IVA_TASA&#34;&#62;*0.01)+&#60;frDBDetalle.&#34;UNITARIO_EXENTO&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;      Total   :=Unitario*&#60;frDBDetalle.&#34;CANTIDAD&#34;&#62;;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_Total&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;        Total   :=&#60;frDBDetalle.&#34;Total&#34;&#62;;&#13;&#10;    end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Memo15.visible  :=&#60;ImpUnitario&#62;='S';&#13;&#10;  Memo15.Printable:=&#60;ImpUnitario&#62;='S';&#13;&#10;  Memo52.visible  :=&#60;ImpTotal&#62;='S';&#13;&#10;  Memo52.Printable:=&#60;ImpTotal&#62;='S';&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupFooter1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      SUnitario:=&#60;frDBDetalle.&#34;ITEMGRAVADO&#34;&#62;+&#60;frDBDetalle.&#34;ITEMEXENTO&#34;&#62;+&#60;frDBDetalle.&#34;ITEMIVA&#34;&#62;;&#13;&#10;      STotal   :=&#60;frDBDetalle.&#34;ITEMCANTIDAD&#34;&#62;*SUnitario;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;       SUnitario:=&#60;frDBDetalle.&#34;ITEMGRAVADO&#34;&#62;+&#60;frDBDetalle.&#34;ITEMEXENTO&#34;&#62;;&#13;&#10;       STotal   :=&#60;frDBDetalle.&#34;ITEMCANTIDAD&#34;&#62;*SUnitario;&#13;&#10;    end;&#13;&#10;  TotalItem := TotalItem + STotal;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure DetailData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_GRAVADO&#34;&#62;*(1+&#60;frDBDetalle.&#34;IVA_TASA&#34;&#62;*0.01)+&#60;frDBDetalle.&#34;UNITARIO_EXENTO&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;      Total   :=Unitario*&#60;frDBDetalle.&#34;CANTIDAD&#34;&#62;;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_Total&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;        Total   :=&#60;frDBDetalle.&#34;Total&#34;&#62;;&#13;&#10;    end;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.">
