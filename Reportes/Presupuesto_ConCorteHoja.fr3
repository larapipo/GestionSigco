<TfrxReport Version="2022.2.3" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.MDIChild="True" PreviewOptions.Modal="False" PreviewOptions.Zoom="1" PrintOptions.Printer="Microsoft Print to PDF" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="39638.1218721644" ReportOptions.Description.Text="" ReportOptions.LastChange="45169.6874175231" ScriptLanguage="PascalScript" ScriptText.Text="var Unitario,Total:Real;&#13;&#10;Lineas,Contador:Integer;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure MasterData4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Contador:=Contador+1;&#13;&#10;  if &#60;frDBDetalle.&#34;ACEPTADO&#34;&#62;='S' Then&#13;&#10;    MasterData4.Visible:=True&#13;&#10;  else&#13;&#10;    MasterData4.Visible:=False;&#13;&#10;&#13;&#10;  if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      Unitario:=&#60;frDBDetalle.&#34;UNITARIO_GRAVADO&#34;&#62;*(1+&#60;frDBDetalle.&#34;IVA_TASA&#34;&#62;*0.01)+&#60;frDBDetalle.&#34;UNITARIO_EXENTO&#34;&#62;;&#13;&#10;      Unitario:=Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;      Total   :=Unitario*&#60;frDBDetalle.&#34;CANTIDAD&#34;&#62;;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      Unitario:= &#60;frDBDetalle.&#34;UNITARIO_Total&#34;&#62;;&#13;&#10;      Unitario:= Unitario * (1-&#60;frDBDetalle.&#34;DESCUENTO&#34;&#62;*0.01);&#13;&#10;      Total   := &#60;frDBDetalle.&#34;Total&#34;&#62;;&#13;&#10;    end;&#13;&#10;  Lineas:=MasterData4.DataSet.RecordCount;&#13;&#10;&#13;&#10;  Memo26.Visible:=True;&#13;&#10;  Memo24.Visible:=True;&#13;&#10;  Memo16.Visible:=True;&#13;&#10;  Memo47.Visible:=True;&#13;&#10;  Memo50.Visible:=True;&#13;&#10;&#13;&#10;  Memo29.Visible:=True;&#13;&#10;  Memo25.Visible:=True;&#13;&#10;  Memo30.Visible:=True;&#13;&#10;  Memo42.Visible:=True;&#13;&#10;  Memo48.Visible:=True;&#13;&#10;  Memo47.Visible:=True;&#13;&#10;&#13;&#10;  begin&#13;&#10;  //  Memo50.Visible:=False;&#13;&#10;    if Contador &#62;= Lineas then&#13;&#10;      begin&#13;&#10;        if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;          begin&#13;&#10;            Subreport1.visible   :=False;&#13;&#10;            Memo25.Visible       :=True;&#13;&#10;            Memo30.Visible       :=False;&#13;&#10;            Memo24.Visible       :=True;&#13;&#10;            Memo16.Visible       :=False;&#13;&#10;         end&#13;&#10;       else&#13;&#10;         begin&#13;&#10;           Subreport1.visible :=True;&#13;&#10;           Memo29.Visible     :=True;&#13;&#10;           Memo25.Visible     :=True;&#13;&#10;           Memo30.Visible     :=True;&#13;&#10;&#13;&#10;           Memo26.Visible     :=True;&#13;&#10;           Memo24.Visible     :=True;&#13;&#10;           Memo16.Visible     :=True;&#13;&#10;         end;&#13;&#10;      end&#13;&#10;    else&#13;&#10;      begin&#13;&#10;        Memo26.Visible:=False;&#13;&#10;        Memo24.Visible:=False;&#13;&#10;        Memo16.Visible:=False;&#13;&#10;        Memo47.Visible:=False;&#13;&#10;        Memo50.Visible:=True;&#13;&#10;        Memo29.Visible:=False;&#13;&#10;        Memo25.Visible:=False;&#13;&#10;        Memo30.Visible:=False;&#13;&#10;        Memo42.Visible:=False;&#13;&#10;        Memo48.Visible:=False;&#13;&#10;        Memo47.Visible:=False;&#13;&#10;      end;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure ReportSummary1OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Memo50.Visible:=False;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure PageHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  if &#60;frDBCabecera.&#34;DESGLOZAIVA&#34;&#62;='N' Then&#13;&#10;    begin&#13;&#10;      Subreport1.visible   := False;&#13;&#10;      Subreport1.printable := False;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      Subreport1.visible   := True;&#13;&#10;      Subreport1.printable := True;&#13;&#10;    end&#13;&#10;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  Contador:=0;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;end.">
