<TfrxReport Version="2024.1.8" DotMatrixReport="False" IniFile="\Software\Fast Reports" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="Brother HL-2130 series (72 redireccionado)" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="39638.1218510648" ReportOptions.Description.Text="" ReportOptions.LastChange="45706.7718179861" ScriptLanguage="PascalScript" ScriptText.Text="var&#13;&#10;TotalGravado,TotalExento,TotalPercIB,TotalGeneral,&#13;&#10;Col1,Col2,Col3,Col4,Col5,Col6,&#13;&#10;SumaNeto,SumaImp,SumaExe,SumaTotal,SumaLinea,&#13;&#10;TSumaNeto,TSumaImp,TSumaExe,TSumaTotal:Extended;&#13;&#10;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  MasterData1.Font.Color := clBlack;&#13;&#10;&#13;&#10; if (&#60;frDBLibroIva.&#34;ANULADO&#34;&#62;='N') Then&#13;&#10;   begin&#13;&#10;     Memo7.Visible:=False;&#13;&#10;     Memo3.Visible:=True;&#13;&#10;     Memo6.Visible:=True;&#13;&#10;     Memo31.Visible:=True;&#13;&#10;     Memo61.Visible:=True;&#13;&#10;     Memo69.Visible:=True;&#13;&#10;     Memo70.Visible:=True;&#13;&#10;     Memo71.Visible:=True;&#13;&#10;&#13;&#10;     if (&#60;frDBLibroIva.&#34;TIPO_CPBTE&#34;&#62;='FC') or&#13;&#10;        (&#60;frDBLibroIva.&#34;TIPO_CPBTE&#34;&#62;='ND') or&#13;&#10;        (&#60;frDBLibroIva.&#34;TIPO_CPBTE&#34;&#62;='TK') or&#13;&#10;        (&#60;frDBLibroIva.&#34;TIPO_CPBTE&#34;&#62;='FO') Then&#13;&#10;       begin&#13;&#10;         TotalGravado :=TotalGravado+&#60;frDBLibroIva.&#34;NETO_GRAVADO&#34;&#62;;&#13;&#10;         TotalExento  :=TotalExento+&#60;frDBLibroIva.&#34;NETO_EXENTO&#34;&#62;;&#13;&#10;         TotalGeneral :=TotalGeneral+&#60;frDBLibroIva.&#34;TOTAL&#34;&#62;;&#13;&#10;         TotalPERCIB  :=TotalPERCIB+&#60;frDBLibroIva.&#34;PERC_IB&#34;&#62;;&#13;&#10;         col1:=col1+&#60;frDBLibroIva.&#34;COL1&#34;&#62;;&#13;&#10;         col2:=col2+&#60;frDBLibroIva.&#34;COL2&#34;&#62;;&#13;&#10;         col3:=col3+&#60;frDBLibroIva.&#34;COL3&#34;&#62;;&#13;&#10;         col4:=col4+&#60;frDBLibroIva.&#34;COL4&#34;&#62;;&#13;&#10;         col5:=col5+&#60;frDBLibroIva.&#34;COL5&#34;&#62;;&#13;&#10;    //     col6:=col6+&#60;frDBLibroIva.&#34;COL6&#34;&#62;;&#13;&#10;&#13;&#10;       end&#13;&#10;     else&#13;&#10;       begin&#13;&#10;         TotalGravado :=TotalGravado-&#60;frDBLibroIva.&#34;NETO_GRAVADO&#34;&#62;;&#13;&#10;         TotalExento  :=TotalExento-&#60;frDBLibroIva.&#34;NETO_EXENTO&#34;&#62;;&#13;&#10;         TotalGeneral :=TotalGeneral-&#60;frDBLibroIva.&#34;TOTAL&#34;&#62;;&#13;&#10;         TotalPERCIB  :=TotalPERCIB-&#60;frDBLibroIva.&#34;PERC_IB&#34;&#62;;&#13;&#10;         col1:=col1-&#60;frDBLibroIva.&#34;COL1&#34;&#62;;&#13;&#10;         col2:=col2-&#60;frDBLibroIva.&#34;COL2&#34;&#62;;&#13;&#10;         col3:=col3-&#60;frDBLibroIva.&#34;COL3&#34;&#62;;&#13;&#10;         col4:=col4-&#60;frDBLibroIva.&#34;COL4&#34;&#62;;&#13;&#10;         col5:=col5-&#60;frDBLibroIva.&#34;COL5&#34;&#62;;&#13;&#10;      //   col6:=col6-&#60;frDBLibroIva.&#34;COL6&#34;&#62;;&#13;&#10;       end;&#13;&#10;   end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      MasterData1.Font.Color := clRed;&#13;&#10;      Memo7.Visible :=True;&#13;&#10;      Memo3.Visible :=False;&#13;&#10;      Memo6.Visible :=False;&#13;&#10;      Memo31.Visible:=False;&#13;&#10;      Memo61.Visible:=False;&#13;&#10;      Memo69.Visible:=False;&#13;&#10;      Memo70.Visible:=False;&#13;&#10;      Memo71.Visible:=False;&#13;&#10;    end;&#13;&#10;  if (&#60;frDBLibroIva.&#34;TIPO_CPBTE&#34;&#62;='NC') and (&#60;frDBLibroIva.&#34;ANULADO&#34;&#62;='N') Then&#13;&#10;    MasterData1.Font.Color := clBlue;&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;&#13;&#10;procedure GroupHeader2OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  SumaNeto :=0;&#13;&#10;  SumaImp  :=0;&#13;&#10;  SumaExe  :=0;&#13;&#10;  SumaTotal:=0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData4OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  IF &#60;frDBTotalesPorCategoria.&#34;TIPOCPBTE&#34;&#62;&#60;&#62;'NC' Then&#13;&#10;    begin&#13;&#10;      SumaNeto :=SumaNeto  + &#60;frDBTotalesPorCategoria.&#34;MUESTRANETO&#34;&#62;;&#13;&#10;      SumaImp  :=SumaImp   + &#60;frDBTotalesPorCategoria.&#34;MUESTRAIMPUESTO&#34;&#62;;&#13;&#10;      SumaExe  :=SumaExe   + &#60;frDBTotalesPorCategoria.&#34;TOTALEXENTO&#34;&#62;;&#13;&#10;      SumaTotal:=SumaTotal + SumaLinea;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    begin&#13;&#10;      SumaNeto :=SumaNeto  + &#60;frDBTotalesPorCategoria.&#34;MUESTRANETO&#34;&#62;;&#13;&#10;      SumaImp  :=SumaImp   + &#60;frDBTotalesPorCategoria.&#34;MUESTRAIMPUESTO&#34;&#62;;&#13;&#10;      SumaExe  :=SumaExe   + &#60;frDBTotalesPorCategoria.&#34;TOTALEXENTO&#34;&#62;;&#13;&#10;      SumaTotal:=SumaTotal + SumaLinea;&#13;&#10;    end;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TSumaNeto :=0;&#13;&#10;  TSumaImp  :=0;&#13;&#10;  TSumaExe  :=0;&#13;&#10;  TSumaTotal:=0;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure GroupFooter3OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  TSumaNeto :=TSumaNeto + SumaNeto;&#13;&#10;  TSumaImp  :=TSumaImp  + SumaImp;&#13;&#10;  TSumaExe  :=TSumaExe  + SumaExe;&#13;&#10;  TSumaTotal:=TSumaTotal+ SumaTotal;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData4OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  SumaLinea:=0;&#13;&#10;  SumaLinea:=&#60;frDBTotalesPorCategoria.&#34;MUESTRANETO&#34;&#62;+&#13;&#10;             &#60;frDBTotalesPorCategoria.&#34;MUESTRAIMPUESTO&#34;&#62;+&#13;&#10;             &#60;frDBTotalesPorCategoria.&#34;TOTALEXENTO&#34;&#62;+&#60;frDBTotalesPorCategoria.&#34;TOTALIIBB&#34;&#62;;&#13;&#10;// SumaLinea:=&#60;frDBTotalesPorCategoria.&#34;TOTAL&#34;&#62;;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData5OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;  if &#60;porjuri&#62; ='J' Then  GroupHeader4.Visible:=True else&#13;&#10;    GroupHeader4.Visible:=False;&#13;&#10;&#13;&#10;&#13;&#10;end.">
