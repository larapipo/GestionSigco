<TfrxReport ScriptLanguage="PascalScript" ScriptText.text="procedure DetalleOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with Detalle, Engine do&#13;&#10;  begin&#13;&#10;  Lin:=0;&#13;&#10;  RenglonBlanco.Height:=Detalle.Height*(10-[Line#]);&#13;&#10;  Lin:=RenglonBlanco.Height;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure PageHeader1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with PageHeader1, Engine do&#13;&#10;  begin&#13;&#10;  if [DatosVentasCtdo.wwCDSVentaCab.&#34;DESGLOZAIVA&#34;]='N' Then&#13;&#10;    begin&#13;&#10;      DetalleIva.Visible   :=False;&#13;&#10;      DetalleExento.Visible:=False;&#13;&#10;      DetalleTotal.Visible :=False;&#13;&#10;    end&#13;&#10;  else&#13;&#10;    if [DatosVentasCtdo.wwCDSVentaCab.&#34;DESGLOZAIVA&#34;]='S' Then&#13;&#10;      begin&#13;&#10;        DetalleIva.Visible   :=True;&#13;&#10;        DetalleExento.Visible:=True;&#13;&#10;        DetalleTotal.Visible :=True;&#13;&#10;      end;&#13;&#10;  &#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;procedure RenglonBlancoOnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  with RenglonBlanco, Engine do&#13;&#10;  begin&#13;&#10;&#13;&#10;  end&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end.&#13;&#10;" Propdata="" ReportOptions.Name="" ReportOptions.Author="" ReportOptions.Description.text="" ReportOptions.CreateDate="39638,121849213" ReportOptions.LastChange="39638,121849213" ReportOptions.VersionMajor="" ReportOptions.VersionMinor="" ReportOptions.VersionRelease="" ReportOptions.VersionBuild="" ReportOptions.Password="">
